<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Đăng ký – E-Learning</title>
</head>
<body class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 flex items-center justify-center p-4">

  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-70"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-purple-100 rounded-full blur-3xl opacity-70"></div>
  </div>

  <div class="w-full max-w-md relative z-10">

    <!-- Brand -->
    <div class="text-center mb-8">
      <a href="/" class="inline-flex flex-col items-center gap-3">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl shadow-lg shadow-indigo-200 flex items-center justify-center">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Tạo tài khoản</h1>
          <p class="text-gray-500 text-sm mt-1">Đăng ký để bắt đầu hành trình học tập</p>
        </div>
      </a>
    </div>

    <!-- Card -->
    <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-xl shadow-gray-100/80">

      <!-- Error alert -->
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="flex items-start gap-3 bg-red-50 border border-red-100 text-red-600 rounded-xl p-4 mb-6">
        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <span class="text-sm font-medium"><%= error %></span>
      </div>
      <% } %>

      <form action="/register" method="POST" id="registerForm" novalidate>

        <!-- Username -->
        <div class="mb-4">
          <label for="username" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Tên đăng nhập
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <input type="text" name="username" id="username"
                   value="<%= typeof formData !== 'undefined' ? (formData.username || '') : '' %>"
                   placeholder="Ví dụ: hocvien123"
                   autocomplete="username"
                   class="w-full border border-gray-200 rounded-xl pl-10 pr-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/60 focus:border-indigo-400 transition-all">
          </div>
          <p id="usernameError" class="mt-1 text-xs text-red-500 hidden"></p>
          <p class="mt-1 text-xs text-gray-400">Từ 3–50 ký tự, chỉ dùng chữ cái, số và dấu gạch dưới (_)</p>
        </div>

        <!-- Email -->
        <div class="mb-4">
          <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Địa chỉ Email
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <input type="email" name="email" id="email"
                   value="<%= typeof formData !== 'undefined' ? (formData.email || '') : '' %>"
                   placeholder="Ví dụ: example@gmail.com"
                   autocomplete="email"
                   class="w-full border border-gray-200 rounded-xl pl-10 pr-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/60 focus:border-indigo-400 transition-all">
          </div>
          <p id="emailError" class="mt-1 text-xs text-red-500 hidden"></p>
          <p class="mt-1 text-xs text-gray-400">Dùng để xác thực tài khoản. Kiểm tra hộp thư sau khi đăng ký.</p>
        </div>

        <!-- Password -->
        <div class="mb-4">
          <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Mật khẩu
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <input type="password" name="password" id="password"
                   placeholder="Ít nhất 6 ký tự"
                   autocomplete="new-password"
                   class="w-full border border-gray-200 rounded-xl pl-10 pr-11 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/60 focus:border-indigo-400 transition-all">
            <button type="button" id="togglePassword"
                    class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-gray-400 hover:text-gray-600 transition-colors">
              <svg id="eyeOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              <svg id="eyeClosed" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
              </svg>
            </button>
          </div>
          <p id="passwordError" class="mt-1 text-xs text-red-500 hidden"></p>

          <!-- Password strength bar -->
          <div class="mt-2 flex gap-1" id="strengthBars">
            <div class="h-1 flex-1 rounded-full bg-gray-100" id="bar1"></div>
            <div class="h-1 flex-1 rounded-full bg-gray-100" id="bar2"></div>
            <div class="h-1 flex-1 rounded-full bg-gray-100" id="bar3"></div>
            <div class="h-1 flex-1 rounded-full bg-gray-100" id="bar4"></div>
          </div>
          <p id="strengthLabel" class="mt-1 text-xs text-gray-400"></p>
        </div>

        <!-- Confirm Password -->
        <div class="mb-6">
          <label for="confirmPassword" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Xác nhận mật khẩu
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <input type="password" name="confirmPassword" id="confirmPassword"
                   placeholder="Nhập lại mật khẩu"
                   autocomplete="new-password"
                   class="w-full border border-gray-200 rounded-xl pl-10 pr-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/60 focus:border-indigo-400 transition-all">
          </div>
          <p id="confirmError" class="mt-1 text-xs text-red-500 hidden"></p>
        </div>

        <!-- Submit -->
        <button type="submit" id="submitBtn"
                class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-semibold py-2.5 px-6 rounded-xl transition-all duration-200 shadow-md shadow-indigo-200 hover:shadow-lg hover:shadow-indigo-200 hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:translate-y-0">
          <svg id="submitIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
          <svg id="loadingIcon" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span id="submitText">Tạo tài khoản</span>
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-6">
        Đã có tài khoản?
        <a href="/login" class="text-indigo-600 hover:text-indigo-500 font-semibold transition-colors">Đăng nhập</a>
      </p>
    </div>

    <p class="text-center text-gray-400 text-xs mt-6">© 2025 E-Learning Platform. Tất cả quyền được bảo lưu.</p>
  </div>

  <script>
    // Toggle password visibility
    document.getElementById('togglePassword').addEventListener('click', () => {
      const pw = document.getElementById('password');
      const isPassword = pw.type === 'password';
      pw.type = isPassword ? 'text' : 'password';
      document.getElementById('eyeOpen').classList.toggle('hidden', isPassword);
      document.getElementById('eyeClosed').classList.toggle('hidden', !isPassword);
    });

    // Password strength meter
    document.getElementById('password').addEventListener('input', function () {
      const val = this.value;
      const bars = [document.getElementById('bar1'), document.getElementById('bar2'), document.getElementById('bar3'), document.getElementById('bar4')];
      const label = document.getElementById('strengthLabel');
      bars.forEach(b => { b.className = 'h-1 flex-1 rounded-full bg-gray-100'; });

      if (!val) { label.textContent = ''; return; }

      let score = 0;
      if (val.length >= 6) score++;
      if (val.length >= 10) score++;
      if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      const configs = [
        { color: 'bg-red-400', text: 'Yếu', textClass: 'text-red-500' },
        { color: 'bg-orange-400', text: 'Trung bình', textClass: 'text-orange-500' },
        { color: 'bg-yellow-400', text: 'Khá', textClass: 'text-yellow-600' },
        { color: 'bg-green-500', text: 'Mạnh', textClass: 'text-green-600' },
      ];
      const cfg = configs[score - 1] || configs[0];
      for (let i = 0; i < score; i++) bars[i].classList.replace('bg-gray-100', cfg.color);
      label.textContent = cfg.text;
      label.className = `mt-1 text-xs ${cfg.textClass}`;
    });

    // Form validation
    document.getElementById('registerForm').addEventListener('submit', function (e) {
      const username = document.getElementById('username').value.trim();
      const email    = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const confirm  = document.getElementById('confirmPassword').value;

      const errEls = {
        username: document.getElementById('usernameError'),
        email:    document.getElementById('emailError'),
        password: document.getElementById('passwordError'),
        confirm:  document.getElementById('confirmError'),
      };
      Object.values(errEls).forEach(el => el.classList.add('hidden'));
      let valid = true;

      const showErr = (key, msg) => {
        errEls[key].textContent = msg;
        errEls[key].classList.remove('hidden');
        valid = false;
      };

      if (!username) showErr('username', 'Vui lòng nhập tên đăng nhập.');
      else if (username.length < 3) showErr('username', 'Tên đăng nhập phải có ít nhất 3 ký tự.');
      else if (!/^[a-zA-Z0-9_]+$/.test(username)) showErr('username', 'Chỉ được dùng chữ cái, số và dấu gạch dưới.');

      if (!email) showErr('email', 'Vui lòng nhập địa chỉ email.');
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) showErr('email', 'Địa chỉ email không hợp lệ.');

      if (!password) showErr('password', 'Vui lòng nhập mật khẩu.');
      else if (password.length < 6) showErr('password', 'Mật khẩu phải có ít nhất 6 ký tự.');

      if (!confirm) showErr('confirm', 'Vui lòng xác nhận mật khẩu.');
      else if (password && confirm !== password) showErr('confirm', 'Mật khẩu xác nhận không khớp.');

      if (!valid) { e.preventDefault(); return; }

      document.getElementById('submitBtn').disabled = true;
      document.getElementById('submitIcon').classList.add('hidden');
      document.getElementById('loadingIcon').classList.remove('hidden');
      document.getElementById('submitText').textContent = 'Đang xử lý...';
    });
  </script>
</body>
</html>
