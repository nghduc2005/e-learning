</style>

<script>
// Accordion toggle
document.querySelectorAll('.cd-unit-header').forEach(btn => {
  btn.addEventListener('click', () => {
    const bodyId = btn.dataset.unit;
    const body = document.getElementById(bodyId);
    const isOpen = btn.classList.contains('open');
    btn.classList.toggle('open', !isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    body.classList.toggle('open', !isOpen);
  });
});

// Star rating picker
(function() {
  const group = document.getElementById('rv-star-select');
  if (!group) return;

  const btns = group.querySelectorAll('.rv-star-btn');
  const input = document.getElementById('rv-rating-input');
  const submit = document.getElementById('rv-submit-btn');
  let selected = 0;

  btns.forEach(btn => {
    const val = parseInt(btn.dataset.value, 10);

    btn.addEventListener('click', () => {
      selected = val;
      input.value = val;
      submit.disabled = false;
      btns.forEach(b => {
        b.classList.toggle('active', parseInt(b.dataset.value, 10) <= val);
      });
    });

    btn.addEventListener('mouseenter', () => {
      btns.forEach(b => {
        const v = parseInt(b.dataset.value, 10);
        b.classList.toggle('hover', v <= val && v > selected);
      });
    });

    btn.addEventListener('mouseleave', () => {
      btns.forEach(b => b.classList.remove('hover'));
    });
  });
})();
</script>
