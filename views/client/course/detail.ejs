<!-- ===== COURSE DETAIL PAGE ===== -->

<!-- Hero / Banner -->
<div class="cd-hero">
  <% if (course.banner) { %>
    <div class="cd-hero-img" style="background-image:url('<%= course.banner %>')"></div>
  <% } else { %>
    <div class="cd-hero-gradient" data-hash="<%= course.id % 6 %>"></div>
  <% } %>
  <div class="cd-hero-overlay"></div>

  <div class="cd-hero-content">
    <div class="cd-header-top">
      <a href="/" class="cd-back-link" id="cd-back-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Quay lại trang chủ
      </a>
      <div class="cd-status-badge cd-status-badge--<%= course.status %>">
        <span class="cd-status-dot"></span>
        <%= course.status === 'active' ? 'Đang mở đăng ký' : 'Tạm khoá' %>
      </div>
    </div>
    <h1 class="cd-title"><%= course.name %></h1>
    <!-- <p class="cd-subtitle"><%= course.shortDescription || 'Khoá học chất lượng cao dành cho bạn.' %></p> -->

    <div class="cd-meta-row">
      <div class="cd-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span><strong><%= course.studentCount %></strong> học viên</span>
      </div>
      <% if (course.avgRating) { %>
        <div class="cd-meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span><strong><%= course.avgRating.toFixed(1) %></strong> (<%= course.reviewCount %> đánh giá)</span>
        </div>
      <% } %>
      <div class="cd-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>Tạo ngày <strong><%= new Date(course.createdAt).toLocaleDateString('vi-VN') %></strong></span>
      </div>
    </div>
  </div>
</div>

<!-- ===== MAIN BODY ===== -->
<div class="cd-body">
  <div class="cd-container">

    <!-- Left: Curriculum -->
    <main class="cd-main">

      <!-- Stats bar -->
      <div class="cd-stats-bar">
        <div class="cd-stat">
          <span class="cd-stat-num"><%= course.units.length %></span>
          <span class="cd-stat-label">Chương</span>
        </div>
        <div class="cd-stat-divider"></div>
        <div class="cd-stat">
          <span class="cd-stat-num"><%= course.units.reduce((s, u) => s + u.lessons.length, 0) %></span>
          <span class="cd-stat-label">Bài học</span>
        </div>
        <div class="cd-stat-divider"></div>
        <div class="cd-stat">
          <span class="cd-stat-num"><%= course.studentCount %></span>
          <span class="cd-stat-label">Học viên</span>
        </div>
        <% if (course.avgRating) { %>
          <div class="cd-stat-divider"></div>
          <div class="cd-stat">
            <span class="cd-stat-num"><%= course.avgRating.toFixed(1) %> ⭐</span>
            <span class="cd-stat-label">Điểm đánh giá</span>
          </div>
        <% } %>
      </div>

      <!-- Course description (HTML) -->
      <% if (course.description) { %>
        <section class="cd-description" id="cd-description">
          <h2 class="cd-section-title">Giới thiệu khoá học</h2>
          <div class="cd-prose">
            <%- course.description %>
          </div>
        </section>
      <% } %>

      <!-- Curriculum accordion -->
      <section class="cd-curriculum" id="cd-curriculum">
        <h2 class="cd-section-title">Nội dung khoá học</h2>

        <% if (course.units.length === 0) { %>
          <div class="cd-empty">
            <span class="cd-empty-icon">📋</span>
            <p>Nội dung khoá học đang được chuẩn bị.</p>
          </div>
        <% } else { %>
          <div class="cd-accordion" id="cd-accordion">
            <% course.units.forEach(function(unit, ui) { %>
              <div class="cd-unit" id="unit-<%= unit.id %>">
                <button
                  class="cd-unit-header <%= ui === 0 ? 'open' : '' %>"
                  aria-expanded="<%= ui === 0 ? 'true' : 'false' %>"
                  data-unit="unit-body-<%= unit.id %>"
                >
                  <div class="cd-unit-left">
                    <span class="cd-unit-index"><%= ui + 1 %></span>
                    <div>
                      <span class="cd-unit-name"><%= unit.name %></span>
                      <span class="cd-unit-count"><%= unit.lessons.length %> bài học</span>
                    </div>
                  </div>
                  <svg class="cd-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                </button>

                <div class="cd-unit-body <%= ui === 0 ? 'open' : '' %>" id="unit-body-<%= unit.id %>">
                  <% if (unit.lessons.length === 0) { %>
                    <div class="cd-lesson-empty">Chưa có bài học nào trong chương này.</div>
                  <% } else { %>
                    <% unit.lessons.forEach(function(lesson, li) { %>
                      <div class="cd-lesson-row <%= lesson.status === 'locked' ? 'cd-lesson-row--locked' : '' %>"
                           id="lesson-row-<%= lesson.id %>">
                        <div class="cd-lesson-icon">
                          <% if (lesson.status === 'locked') { %>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                          <% } else if (lesson.learnMode === 'video') { %>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                          <% } else { %>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                          <% } %>
                        </div>
                        <div class="cd-lesson-info">
                          <span class="cd-lesson-num"><%= ui + 1 %>.<%= li + 1 %></span>
                          <span class="cd-lesson-name"><%= lesson.name %></span>
                        </div>
                        <div class="cd-lesson-tags">
                          <span class="cd-tag cd-tag--mode"><%= lesson.learnMode === 'video' ? '▶ Video' : '📄 Bài đọc' %></span>
                          <% if (lesson.status === 'locked') { %>
                            <span class="cd-tag cd-tag--locked">Khoá</span>
                          <% } %>
                          <% if (lesson.passScore > 0) { %>
                            <span class="cd-tag cd-tag--score">Trắc nghiệm</span>
                          <% } %>
                        </div>
                      </div>
                    <% }); %>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <!-- ===== REVIEWS SECTION ===== -->
      <section class="cd-reviews" id="reviews-section">
        <h2 class="cd-section-title">Đánh giá từ học viên</h2>

        <!-- Rating Overview -->
        <div class="rv-overview">
          <div class="rv-score-box">
            <span class="rv-big-score"><%= course.avgRating ? course.avgRating.toFixed(1) : '–' %></span>
            <div class="rv-stars-row">
              <% for (let s = 1; s <= 5; s++) { %>
                <svg class="rv-star <%= (course.avgRating && s <= Math.round(course.avgRating)) ? 'rv-star--filled' : '' %>" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              <% } %>
            </div>
            <span class="rv-total"><%= reviews.length %> đánh giá</span>
          </div>

          <div class="rv-bars">
            <% for (let star = 5; star >= 1; star--) { %>
              <div class="rv-bar-row">
                <span class="rv-bar-label"><%= star %> ⭐</span>
                <% 
                    let fillPercent = 0;
                    if (reviews.length) {
                      let count = ratingDist[star - 1] || 0;
                      fillPercent = Math.round((count / reviews.length) * 100);
                    }
                  %>
                  <div class="rv-bar-fill" style="--percent: <%= fillPercent %>%; width: var(--percent);"></div>
                <span class="rv-bar-count"><%= ratingDist[star - 1] %></span>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Review Form (only if logged in & not yet reviewed) -->
        <% if (typeof user !== 'undefined' && user && !userReview) { %>
          <div class="rv-form-card" id="rv-form-card">
            <h3 class="rv-form-title">Viết đánh giá của bạn</h3>
            <form action="/courses/<%= course.id %>/review" method="POST" class="rv-form" id="rv-form">
              <div class="rv-star-select" id="rv-star-select">
                <span class="rv-star-label">Đánh giá:</span>
                <div class="rv-star-group">
                  <% for (let s = 1; s <= 5; s++) { %>
                    <button type="button" class="rv-star-btn" data-value="<%= s %>" aria-label="<%= s %> sao">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    </button>
                  <% } %>
                </div>
                <input type="hidden" name="ratingNum" id="rv-rating-input" value="" required>
              </div>
              <textarea
                name="content"
                class="rv-textarea"
                id="rv-textarea"
                rows="3"
                placeholder="Chia sẻ trải nghiệm học tập của bạn..."
                maxlength="1000"
              ></textarea>
              <button type="submit" class="btn btn-primary rv-submit-btn" id="rv-submit-btn" disabled>
                Gửi đánh giá
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </button>
            </form>
          </div>
        <% } else if (typeof user !== 'undefined' && user && userReview) { %>
          <div class="rv-form-card rv-already">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Bạn đã đánh giá khoá học này (<strong><%= userReview.ratingNum %> ⭐</strong>)</span>
          </div>
        <% } else if (!user) { %>
          <div class="rv-form-card rv-login-prompt">
            <a href="/login" class="btn btn-ghost">Đăng nhập để đánh giá</a>
          </div>
        <% } %>

        <!-- Reviews List -->
        <% if (reviews.length > 0) { %>
          <div class="rv-list" id="rv-list">
            <% reviews.forEach(function(review) { %>
              <div class="rv-item" id="review-<%= review.id %>">
                <div class="rv-item-head">
                  <% if (review.avatar) { %>
                    <img src="<%= review.avatar %>" alt="<%= review.username %>" class="rv-avatar">
                  <% } else { %>
                    <span class="rv-avatar rv-avatar--initial"><%= review.username.charAt(0).toUpperCase() %></span>
                  <% } %>
                  <div class="rv-item-info">
                    <span class="rv-username"><%= review.username %></span>
                    <span class="rv-date"><%= review.createdAt %></span>
                  </div>
                  <div class="rv-item-stars">
                    <% for (let s = 1; s <= 5; s++) { %>
                      <svg class="rv-star-sm <%= s <= review.ratingNum ? 'rv-star--filled' : '' %>" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    <% } %>
                  </div>
                </div>
                <% if (review.content) { %>
                  <p class="rv-content"><%= review.content %></p>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="rv-empty">
            <span class="rv-empty-icon">💬</span>
            <p>Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
          </div>
        <% } %>
      </section>

    </main>

    <!-- Right: Enroll card -->
    <aside class="cd-sidebar">
  <div class="cd-enroll-card" id="cd-enroll-card">
    <!-- 1. Hình ảnh đại diện khóa học -->
    <% if (course.banner) { %>
      <img src="<%= course.banner %>" alt="<%= course.name %>" class="cd-enroll-thumb">
    <% } else { %>
      <div class="cd-enroll-thumb cd-enroll-gradient" data-hash="<%= course.id % 6 %>">
        <span class="cd-enroll-gradient-title"><%= course.name %></span>
      </div>
    <% } %>

    <div class="cd-enroll-body">
      <!-- 2. Logic Nút Đăng ký / Vào học -->
      <% if (course.status === 'active') { %>
        <% if (typeof user !== 'undefined' && user) { %>
          
          <% if (enroll) { %>
            <!-- Trường hợp: Đã đăng ký -> Vào học -->
            <a href="/learn/<%= course.id %>/<%= lessonId %>" class="btn btn-primary btn-enroll" id="btn-learn-<%= course.id %>">
              Vào học
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          <% } else { %>
            <!-- Trường hợp: Chưa đăng ký -> Hiện Form POST -->
            <form action="/courses/<%= course.id %>/enroll" method="POST">
              <input type="hidden" name="courseId" value="<%= course.id %>">
              <button type="submit" class="btn btn-primary btn-enroll" id="btn-enroll-<%= course.id %>">
                Đăng ký ngay
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </form>
          <% } %>

        <% } else { %>
          <!-- Trường hợp: Chưa đăng nhập -->
          <a href="/login" class="btn btn-primary btn-enroll" id="btn-login-enroll">
            Đăng nhập để đăng ký
          </a>
          <a href="/register" class="btn btn-ghost btn-enroll-ghost" id="btn-register-enroll">Tạo tài khoản miễn phí</a>
        <% } %>

      <% } else { %>
        <!-- Trường hợp: Khóa học bị khóa/ẩn -->
        <button class="btn btn-locked btn-enroll" disabled id="btn-locked-<%= course.id %>">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Chưa mở đăng ký
        </button>
      <% } %>

      <!-- 3. Danh sách đặc điểm (Features) -->
      <ul class="cd-features">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span><%= course.units.reduce((s, u) => s + u.lessons.length, 0) %> bài học</span>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span><%= course.units.length %> chương học</span>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Học mọi lúc, mọi nơi</span>
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Chứng chỉ hoàn thành</span>
        </li>
      </ul>

    </div> <!-- Kết thúc cd-enroll-body -->
  </div> <!-- Kết thúc cd-enroll-card -->
</aside>

  </div><!-- end cd-container -->
</div><!-- end cd-body -->

<style>
/* ===== COURSE DETAIL PAGE STYLES ===== */

/* Hero */
.cd-hero {
  position: relative;
  min-height: 380px;
  display: flex;
  align-items: flex-end;
  margin-top: var(--nav-h);
  overflow: hidden;
}
.cd-hero-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  filter: brightness(.55);
}
/* Palette matching homepage */
.cd-hero-gradient[data-hash="0"] { position:absolute;inset:0;background:linear-gradient(135deg,#6366f1,#8b5cf6); }
.cd-hero-gradient[data-hash="1"] { position:absolute;inset:0;background:linear-gradient(135deg,#0891b2,#06b6d4); }
.cd-hero-gradient[data-hash="2"] { position:absolute;inset:0;background:linear-gradient(135deg,#7c3aed,#a78bfa); }
.cd-hero-gradient[data-hash="3"] { position:absolute;inset:0;background:linear-gradient(135deg,#0f766e,#14b8a6); }
.cd-hero-gradient[data-hash="4"] { position:absolute;inset:0;background:linear-gradient(135deg,#b45309,#f59e0b); }
.cd-hero-gradient[data-hash="5"] { position:absolute;inset:0;background:linear-gradient(135deg,#be185d,#f472b6); }
.cd-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.3) 55%, transparent 100%);
}
.cd-hero-content {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: var(--sp-2xl) var(--sp-lg);
  color: #fff;
}
.cd-back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: rgba(255,255,255,.85);
  font-size: .85rem;
  font-weight: 600;
  transition: color var(--dur-fast), transform var(--dur-fast);
  white-space: nowrap;
}
.cd-back-link:hover { color: #fff; transform: translateX(-3px); }

.cd-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .4px;
}

.cd-header-top {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2xl);
  align-items: flex-start;            /* Căn giữa theo trục dọc */
  margin-bottom: var(--sp-md);    /* Đẩy khoảng cách xuống tiêu đề bên dưới */
}
.cd-status-badge--active { background: rgba(22,163,74,.25); border: 1px solid rgba(22,163,74,.5); }
.cd-status-badge--locked { background: rgba(100,116,139,.25); border: 1px solid rgba(100,116,139,.5); }
.cd-status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: currentColor;
}
.cd-status-badge--active .cd-status-dot { background: #4ade80; animation: pulse 2s infinite; }
.cd-status-badge--locked .cd-status-dot { background: #94a3b8; }

.cd-title {
  font-size: clamp(1.6rem, 4vw, 2.6rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -.8px;
  margin-bottom: var(--sp-sm);
}
.cd-subtitle {
  font-size: 1rem;
  color: rgba(255,255,255,.82);
  line-height: 1.65;
  max-width: 680px;
  margin-bottom: var(--sp-lg);
}
.cd-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-lg);
}
.cd-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: .875rem;
  color: rgba(255,255,255,.85);
}
.cd-meta-item strong { color: #fff; }

/* Body layout */
.cd-body { background: var(--bg-base); padding: var(--sp-2xl) var(--sp-lg); }
.cd-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: var(--sp-xl);
  align-items: start;
}

/* Stats bar */
.cd-stats-bar {
  display: flex;
  align-items: center;
  gap: var(--sp-lg);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--sp-lg) var(--sp-xl);
  margin-bottom: var(--sp-xl);
  box-shadow: var(--shadow-sm);
}
.cd-stat { text-align: center; }
.cd-stat-num {
  display: block;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--primary);
}
.cd-stat-label { font-size: .78rem; color: var(--text-muted); font-weight: 500; }
.cd-stat-divider { width: 1px; height: 36px; background: var(--border); margin: 0 var(--sp-sm); }

/* Description / Prose */
.cd-description {
  margin-bottom: var(--sp-xl);
}
.cd-prose {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--sp-xl);
  box-shadow: var(--shadow-sm);
  font-size: .9rem;
  line-height: 1.8;
  color: var(--text-secondary);
  word-break: break-word;
  overflow-wrap: break-word;
}
.cd-prose h1, .cd-prose h2, .cd-prose h3, .cd-prose h4 {
  color: var(--text-primary);
  margin-top: 1.5em;
  margin-bottom: .5em;
  line-height: 1.3;
