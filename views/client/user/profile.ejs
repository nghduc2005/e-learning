<link rel="stylesheet" href="/client/assets/css/profile.css">

<div class="profile-container">
    <% if (success) { %>
        <div class="alert alert-success">
            <%= success === 'profile_updated' ? 'Cập nhật thông tin thành công!' : '' %>
            <%= success === 'password_changed' ? 'Đổi mật khẩu thành công!' : '' %>
        </div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-error">
            <%= error === 'password_mismatch' ? 'Mật khẩu xác nhận không khớp.' : '' %>
            <%= error === 'password_too_short' ? 'Mật khẩu phải có ít nhất 6 ký tự.' : '' %>
            <%= typeof error === 'string' && error.length > 20 ? error : '' %>
        </div>
    <% } %>

    <!-- Profile Header -->
    <header class="profile-header">
        <div class="profile-cover"></div>
        <div class="profile-info-row">
            <div class="profile-avatar-wrapper">
                <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="<%= user.username %>" class="profile-avatar" id="profile-avatar-preview">
                <% } else { %>
                    <div class="profile-avatar profile-avatar--initial">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
                <label for="avatar-input" class="avatar-edit-btn" title="Đổi ảnh đại diện">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                </label>
            </div>
            <div class="profile-user-details">
                <h1 class="profile-name"><%= user.username %></h1>
                <span class="profile-username">@<%= user.username %></span>
            </div>
        </div>
    </header>

    <!-- Stats Row -->
    <div class="profile-stats">
        <div class="stat-card">
            <div class="stat-icon stat-icon--blue">📚</div>
            <div class="stat-info">
                <h3><%= user.stats.enrolledCount %></h3>
                <p>Khóa học đã tham gia</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon--green">✅</div>
            <div class="stat-info">
                <h3><%= user.stats.completedLessonsCount %></h3>
                <p>Bài học đã hoàn thành</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon--purple">🏆</div>
            <div class="stat-info">
                <h3>0</h3>
                <p>Chứng chỉ đã nhận</p>
            </div>
        </div>
    </div>

    <div class="profile-grid">
        <!-- Left Side: Forms -->
        <div class="profile-main">
            <section class="profile-section" style="margin-bottom: 30px;">
                <h2 class="section-title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Thông tin cá nhân
                </h2>
                <form action="/profile/update" method="POST" enctype="multipart/form-data" id="profile-form">
                    <input type="file" name="avatar" id="avatar-input" style="display: none" accept="image/*">
                    
                    <div class="form-group">
                        <label>Tên đăng nhập</label>
                        <input type="text" class="form-control" value="<%= user.username %>" disabled>
                        <small style="color: var(--text-muted); font-size: 0.75rem;">Tên đăng nhập không thể thay đổi.</small>
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ Email</label>
                        <input type="email" name="email" class="form-control" value="<%= user.email %>" required>
                    </div>

                    <div style="display: flex; justify-content: flex-end;">
                        <button type="submit" class="btn btn-primary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Lưu thay đổi
                        </button>
                    </div>
                </form>
            </section>

            <section class="profile-section">
                <h2 class="section-title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Đổi mật khẩu
                </h2>
                <form action="/profile/change-password" method="POST">
                    <div class="form-group">
                        <label>Mật khẩu hiện tại</label>
                        <input type="password" name="oldPassword" class="form-control" placeholder="••••••••" required>
                    </div>
                    <div class="form-group">
                        <label>Mật khẩu mới</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="••••••••" required>
                    </div>
                    <div class="form-group">
                        <label>Xác nhận mật khẩu mới</label>
                        <input type="password" name="confirmPassword" class="form-control" placeholder="••••••••" required>
                    </div>
                    <div style="display: flex; justify-content: flex-end;">
                        <button type="submit" class="btn btn-ghost">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L22 22m-2-2l2 2"/></svg>
                            Cập nhật mật khẩu
                        </button>
                    </div>
                </form>
            </section>
        </div>

        <!-- Right Side: Recent Courses -->
        <aside class="profile-sidebar">
            <div class="profile-section">
                <h2 class="section-title">Khóa học gần đây</h2>
                <% if (user.enrolledCourses && user.enrolledCourses.length > 0) { %>
                    <div class="mini-course-list">
                        <% user.enrolledCourses.forEach(course => { %>
                            <a href="/courses/<%= course.id %>" class="mini-course-item">
                                <% if (course.banner) { %>
                                    <img src="<%= course.banner %>" alt="<%= course.name %>" class="mini-course-img">
                                <% } else { %>
                                    <div class="mini-course-img" style="background: linear-gradient(135deg, #6366f1, #a855f7); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.5rem; font-weight: bold; text-align: center; padding: 2px;">
                                        <%= course.name.substring(0, 10) %>...
                                    </div>
                                <% } %>
                                <div class="mini-course-info">
                                    <span class="mini-course-name"><%= course.name %></span>
                                    <span class="mini-course-date">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                        Tham gia: <%= new Date(course.enrolledAt).toLocaleDateString('vi-VN') %>
                                    </span>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                    <a href="/my-courses" class="view-all-btn">Xem tất cả khóa học →</a>
                <% } else { %>
                    <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 20px 0;">
                        Bạn chưa tham gia khóa học nào.
                    </p>
                    <a href="/" class="btn btn-primary" style="width: 100%; justify-content: center; font-size: 0.85rem;">Khám phá ngay</a>
                <% } %>
            </div>
        </aside>
    </div>
</div>

<script>
    // Preview avatar before upload
    const avatarInput = document.getElementById('avatar-input');
    const avatarPreview = document.getElementById('profile-avatar-preview');
    const avatarWrapper = document.querySelector('.profile-avatar-wrapper');

    avatarInput.onchange = evt => {
        const [file] = avatarInput.files;
        if (file) {
            // Check if preview element exists (it might be a div with initials)
            if (avatarPreview) {
                avatarPreview.src = URL.createObjectURL(file);
            } else {
                // Replace initials div with an img element
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'profile-avatar';
                img.id = 'profile-avatar-preview';
                
                const initialsDiv = avatarWrapper.querySelector('.profile-avatar--initial');
                if (initialsDiv) {
                    avatarWrapper.replaceChild(img, initialsDiv);
                }
            }
        }
    }
</script>
