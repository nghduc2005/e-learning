<div class="flex items-center justify-between mb-8">
  <p class="text-sm text-gray-500 mt-1">Vui lòng điền các thông tin để cập nhật bài học.</p>
<a href="javascript:void(0)" onclick="window.opener ? window.close() : history.back()" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 flex items-center transition-colors">
  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  Quay lại danh sách
</a>
</div>
<div class="relative rounded-2xl overflow-x-auto p-6 bg-gray-50 font-sans">
  <form action="/admin/lesson/edit/<%= lesson.id %>" id="editLessonForm" method="POST" enctype="multipart/form-data" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-8 space-y-6">
      <div class="grid grid-cols-2 gap-6 items-end">
        <div class="grid grid-cols-2 col-span-2 gap-6 items-start mt-6">
            <div class="flex flex-col gap-2">
                <label for="title" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                    Tên bài học <span class="text-red-600">*</span>
                </label>
                <input type="text" id="title" name="title" value="<%= lesson.name %>"
                    placeholder="Ví dụ: Lập trình C++"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all placeholder:text-gray-400 text-gray-700">
            </div>
        
            <div class="flex flex-col gap-2">
                <label for="status" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                    Trạng thái <span class="text-red-600">*</span>
                </label>
                <select id="status" name="status" 
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all text-gray-700 appearance-none bg-no-repeat bg-[right_1rem_center] bg-[length:1em_1em]"
                    style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 24 24%22 stroke=%22%236b7280%22%3E%3Cpath stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%222%22 d=%22M19 9l-7 7-7-7%22/%3E%3C/svg%3E');">
                    <option value="hidden" <%= lesson.status === 'hidden' ? 'selected' : '' %>>Ẩn</option>
                    <option value="locked" <%= lesson.status === 'locked' ? 'selected' : '' %>>Khóa</option>
                    <option value="active" <%= lesson.status === 'active' ? 'selected' : '' %>>Hoạt động</option>
                </select>
            </div>
        </div>
        <div class="grid grid-cols-2 col-span-2 gap-6 items-start mt-6">
          <div class="flex flex-col gap-2">
              <label for="learnMode" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                  Chế độ học <span class="text-red-600">*</span>
              </label>
              <div class="relative">
                  <select id="learnMode" name="learnMode" onchange="toggleUploadMode(this.value)"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all text-gray-700 appearance-none bg-no-repeat bg-[right_1rem_center] bg-[length:1em_1em]"
                      style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 24 24%22 stroke=%22%236b7280%22%3E%3Cpath stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%222%22 d=%22M19 9l-7 7-7-7%22/%3E%3C/svg%3E');">
                      <option value="video" <%= lesson.learnMode === 'video' ? 'selected' : '' %>>Học qua Video</option>
                      <option value="article" <%= lesson.learnMode === 'article' ? 'selected' : '' %>>Học qua Bài viết (PDF/Docx)</option>
                  </select>
              </div>
              <p class="text-[11px] text-gray-400 ml-1 italic">Chọn định dạng tài liệu học của bài chính.</p>
          </div>
      
          <div class="flex flex-col gap-2">
              <label id="fileLabel" for="content" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                  <%= lesson.learnMode === 'video' ? 'Video bài giảng' : 'Tài liệu bài giảng' %>
              </label>
              <div class="relative">
                  <input type="file" id="content" name="content" <%= lesson.learnMode === 'video' ? 'accept="video/*"' : 'accept=".pdf,.docx"' %>
                      class="hidden" onchange="handleFileSelect(this)">
                  
                  <label for="content" 
                      class="flex items-center justify-between w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 hover:border-indigo-400 hover:bg-indigo-50 cursor-pointer transition-all group">
                      
                      <div class="flex items-center overflow-hidden">
                          <div id="fileIcon">
                              <svg class="w-6 h-6 text-indigo-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                              </svg>
                          </div>
                          <span id="contentFileName" class="text-gray-900 font-medium truncate" data-initial-content="<%= lesson.content %>">Đã có tài liệu lưu trữ (Chọn để đổi)</span>
                      </div>
                      
                      <span class="text-xs font-bold text-indigo-600 bg-indigo-100 px-3 py-1 rounded-lg uppercase shrink-0">Tải lên</span>
                  </label>
                  <div id="videoPreviewContainer" class="mt-3">
                    <% 
                        // Loại bỏ fl_inline khỏi URL nếu nó tồn tại
                        const downloadUrl = lesson.content.replace('/fl_inline', ''); 
                    %>
                    <% if (lesson.learnMode === 'video' && lesson.content) { %>
                        <% 
                            // Tạo URL xem trực tiếp bằng cách thêm fl_inline và đảm bảo resource_type là video
                            // Cloudinary tự động nhận diện video nếu resource_type là 'video'
                            let videoUrl = lesson.content;
                            if (videoUrl.includes('/upload/')) {
                                videoUrl = videoUrl.replace('/upload/', '/upload/fl_inline/');
                            }
                        %>
                        
                        <div class="flex flex-col gap-2">
                            <span class="text-[11px] text-gray-400 ml-1 uppercase font-bold tracking-wider">Video hiện tại:</span>
                            <a href="<%= downloadUrl %>" target="_blank" 
                                class="flex items-center justify-between p-4 rounded-xl border border-indigo-100 bg-indigo-50/30 hover:bg-indigo-50 hover:border-indigo-200 transition-all group">
                                
                                <div class="flex items-center overflow-hidden">
                                    <div class="shrink-0 mr-3 w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center group-hover:bg-indigo-600 transition-colors">
                                        <svg class="w-5 h-5 text-indigo-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z" />
                                        </svg>
                                    </div>

                                    <div class="flex flex-col overflow-hidden">
                                        <span class="text-sm font-bold text-gray-800 truncate">
                                            Xem video bài giảng
                                        </span>
                                        <span class="text-[10px] text-gray-500 truncate">
                                            Nhấn để mở trình phát video
                                        </span>
                                    </div>
                                </div>

                                <div class="flex items-center text-indigo-600 font-bold text-[10px] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                                    Phát ngay
                                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                    </svg>
                                </div>
                            </a>
                        </div>
                    <% } %>
                    </div>
                  <div id="articlePreviewContainer" class="mt-3">
                    <% if (lesson.learnMode === 'article' && lesson.content) { %>
                        <% 
                            // Ép trình duyệt mở trực tiếp file PDF bằng fl_inline
                            let docUrl = lesson.content;
                            if (docUrl.includes('/upload/')) {
                                docUrl = docUrl.replace('/upload/', '/upload/fl_inline/');
                            }
                            
                            // Kiểm tra định dạng để hiển thị icon phù hợp
                            const isPdf = docUrl.toLowerCase().endsWith('.pdf');
                        %>
                        <div class="flex flex-col gap-2">
                            <span class="text-[11px] text-gray-400 ml-1 uppercase font-bold tracking-wider">Tài liệu chính hiện tại:</span>
                            <a href="<%= downloadUrl %>" target="_blank" 
                            class="flex items-center justify-between p-4 rounded-xl border border-emerald-100 bg-emerald-50/30 hover:bg-emerald-50 hover:border-emerald-200 transition-all group">
                                
                                <div class="flex items-center overflow-hidden">
                                    <div class="shrink-0 mr-3 w-10 h-10 <%= isPdf ? 'bg-red-100' : 'bg-blue-100' %> rounded-xl flex items-center justify-center transition-colors">
                                        <% if (isPdf) { %>
                                            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                            </svg>
                                        <% } else { %>
                                            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        <% } %>
                                    </div>

                                    <div class="flex flex-col overflow-hidden">
                                        <span class="text-sm font-bold text-gray-800 truncate">
                                            Xem nội dung bài viết
                                        </span>
                                        <span class="text-[10px] text-gray-500 truncate">
                                            Định dạng: <%= isPdf ? 'PDF Document' : 'Word Document' %>
                                        </span>
                                    </div>
                                </div>

                                <div class="flex items-center text-emerald-600 font-bold text-[10px] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                                    Đọc tài liệu
                                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
              </div>
              <p id="fileHint" class="text-[11px] text-gray-400 ml-1 italic">* Không bắt buộc tải lại file nếu muốn giữ file cũ.</p>
          </div>
      </div>
        <div class="grid grid-cols-2 col-span-2 gap-6 items-start mt-6">
            <div class="flex flex-col gap-2">
                <label for="score" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                    Số câu hỏi cần đạt <span class="text-red-600">*</span>
                </label>
                <div class="relative">
                    <select id="score" name="score" data-initial-score="<%= lesson.passScore %>"
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all text-gray-700 appearance-none bg-no-repeat bg-[right_1rem_center] bg-[length:1em_1em]"
                        style="background-image: url('data:image/svg+xml;charset=utf-8,...');">
                        <option value="0">0 câu hỏi</option>
                    </select>
                </div>
                <p class="text-[11px] text-gray-400 ml-1 italic">* Học viên cần trả lời đúng ít nhất số câu này để qua bài học.</p>
            </div>
          <div class="flex flex-col gap-2">
              <label for="document" class="text-sm font-bold text-gray-700 uppercase tracking-wider">
                  Tài liệu bài học đính kèm (Docx, PDF)
              </label>
              <div class="relative">
                  <input type="file" id="document" multiple name="document" accept=".pdf,.docx" class="hidden" onchange="updateFileName(this)">
                  <label for="document" class="flex items-center justify-between w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 hover:border-indigo-400 hover:bg-indigo-50 cursor-pointer transition-all group">
                      <div class="flex items-center overflow-hidden">
                          <svg class="w-6 h-6 text-gray-400 group-hover:text-indigo-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                          </svg>
                          <% const docArr = lesson.documents; %>
                          <span id="fileNameDisplay" class="text-gray-900 font-medium truncate"><%= docArr.length > 0 ? `Đã có ${docArr.length} file đính kèm (Chọn để đổi mới)` : 'Chưa chọn file...' %></span>
                      </div>
                      <span class="text-xs font-bold text-indigo-600 bg-indigo-100 px-3 py-1 rounded-lg uppercase shrink-0">Chọn</span>
                  </label>
              </div>
              <p class="text-[11px] text-gray-400 ml-1 italic">* Tối đa 3 file mỗi file tối đa 10MB</p>
              <div id="fileListContainer" class="mt-3 space-y-2">
                
                <% if (docArr.length > 0) { %>
                    <div class="grid grid-cols-1 gap-2">
                        <% docArr.forEach((doc, index) => { %>
                            <a href="<%= doc.url %>" target="_blank" 
                            class="flex items-center justify-between p-3 rounded-xl border border-gray-100 bg-white hover:bg-indigo-50 hover:border-indigo-200 transition-all group">
                                
                                <div class="flex items-center overflow-hidden">
                                    <div class="shrink-0 mr-3">
                                        <% if (doc.fileType === 'pdf') { %>
                                            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                            </svg>
                                        <% } else { %>
                                            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        <% } %>
                                    </div>

                                    <div class="flex flex-col overflow-hidden">
                                        <span class="text-sm font-medium text-gray-700 truncate group-hover:text-indigo-600">
                                            <%= doc.name %>
                                        </span>
                                        <span class="text-[10px] text-gray-400 uppercase font-bold">
                                            Định dạng: <%= doc.fileType %>
                                        </span>
                                    </div>
                                </div>

                                <svg class="w-4 h-4 text-gray-300 group-hover:text-indigo-400 transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                        <% }); %>
                    </div>
                <% } %>
            </div>
          </div>
      
          
        </div>
        <div class="grid grid-cols-2 col-span-2 gap-6">
          <div class="col-span-full mt-8 border-t border-gray-100 pt-8">
              <div id="questionContainer" class="space-y-4">
                  <h3 class="text-sm font-bold text-gray-800 uppercase tracking-wider mb-4 flex items-center">
                      <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      Câu hỏi đính kèm
                  </h3>
              </div>
      
              <button type="button" onclick="addQuestion()" 
                  class="w-full md:w-auto mt-4 inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition-all border border-dashed border-indigo-300">
                  <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  Thêm câu hỏi mới
              </button>
          </div>
      </div>
    </div>
  
    <div class="px-8 py-5 flex items-center justify-end space-x-4 border-t border-gray-100">
      <button data-modal-target="popup-modal" data-modal-toggle="popup-modal" type="button" class="px-6 py-2.5 text-sm font-semibold text-gray-600 hover:text-red-600 transition-colors">
        Hủy bỏ
    </button>
    
    <div id="popup-modal" tabindex="-1" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-[60] justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full bg-gray-900/50 backdrop-blur-sm">
        <div class="relative p-4 w-full max-w-md max-h-full">
            <div class="relative bg-white rounded-2xl shadow-xl border border-gray-100">
                <button type="button" class="absolute top-3 end-2.5 text-gray-400 bg-transparent hover:bg-gray-100 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center" data-modal-hide="popup-modal">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                </button>
    
                <div class="p-6 text-center">
                    <div class="mx-auto mb-4 w-14 h-14 bg-red-50 rounded-full flex items-center justify-center">
                        <svg class="text-red-600 w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="mb-2 text-lg font-bold text-gray-900">Xác nhận hủy?</h3>
                    <p class="mb-6 text-sm text-gray-500">Mọi thông tin bạn vừa nhập sẽ không được lưu lại. Bạn có chắc chắn muốn quay lại danh sách?</p>
                    
                    <div class="flex items-center space-x-3 justify-center">
                        <a href="javascript:void(0)" onclick="window.opener ? window.close() : history.back()" class="text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-bold rounded-xl text-sm inline-flex items-center px-5 py-2.5 text-center transition-all">
                            Có
                        </a>
                        <button data-modal-hide="popup-modal" type="button" class="text-gray-500 bg-white hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-indigo-300 rounded-xl border border-gray-200 text-sm font-bold px-5 py-2.5 hover:text-gray-900 transition-all">
                            Không
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
        <button type="submit" 
            class="inline-flex items-center px-8 py-2.5 text-sm font-bold text-center text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 focus:ring-4 focus:outline-none focus:ring-indigo-300 shadow-lg shadow-indigo-100 transform active:scale-95 transition-all">
            Cập nhật bài học
        </button>
    </div>
  </form>
  </div>
    <%- include('../layouts/components/lazyload.ejs')%>

  <script id="initialQuestionsData" type="application/json">
      <%- JSON.stringify(lesson.questionsList || []) %>
  </script>
  <script>
      window.initialQuestions = JSON.parse(document.getElementById('initialQuestionsData').textContent);
      window.editLessonId = Number('<%= lesson.id %>');
  </script>
  <script src="/admin/assets/js/lessonEdit.js"></script>
