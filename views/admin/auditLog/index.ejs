<p class="text-sm text-gray-500 -mt-4 mb-4">Theo dõi toàn bộ hoạt động của quản trị viên trong hệ thống.</p>

<!-- Thanh tìm kiếm & bộ lọc -->
<div class="flex w-full justify-between items-center mb-6 gap-3 flex-wrap">
  <!-- Search -->
  <form id="searchForm" class="flex-1 min-w-[200px] max-w-sm">
    <div class="relative">
      <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
        <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
        </svg>
      </div>
      <input type="search" id="searchInput" name="q" value="<%= typeof query !== 'undefined' ? new URLSearchParams(query).get('q') || '' : '' %>"
             class="block w-full p-3 ps-10 pe-20 bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 shadow-sm outline-none"
             placeholder="Tìm kiếm hành động, chi tiết..." />
      <button type="submit"
              class="absolute end-1.5 inset-y-1.5 text-white bg-indigo-600 hover:bg-indigo-700 font-medium rounded text-xs px-4 transition-all">
        Tìm
      </button>
    </div>
  </form>

  <!-- Bộ lọc -->
  <div class="flex gap-2 flex-wrap">
    <!-- Lọc theo admin -->
    <select id="filterAdmin" class="h-[42px] px-3 text-sm text-gray-600 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none shadow-sm transition-all">
      <option value="">Tất cả admin</option>
      <% admins.forEach(a => { %>
        <option value="<%= a.id %>" <%= (new URLSearchParams(query).get('adminId') === String(a.id)) ? 'selected' : '' %>>
          <%= a.username %>
        </option>
      <% }) %>
    </select>

    <!-- Lọc theo thời gian -->
    <select id="filterTime" class="h-[42px] px-3 text-sm text-gray-600 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none shadow-sm transition-all">
      <option value="">Tất cả thời gian</option>
      <option value="today" <%= (new URLSearchParams(query).get('time') === 'today') ? 'selected' : '' %>>Hôm nay</option>
      <option value="this_week" <%= (new URLSearchParams(query).get('time') === 'this_week') ? 'selected' : '' %>>7 ngày qua</option>
      <option value="this_month" <%= (new URLSearchParams(query).get('time') === 'this_month') ? 'selected' : '' %>>Tháng này</option>
      <option value="3_months" <%= (new URLSearchParams(query).get('time') === '3_months') ? 'selected' : '' %>>3 tháng qua</option>
    </select>

    <!-- Xóa bộ lọc -->
    <button id="btnClear" class="h-[42px] px-3 text-sm text-gray-500 bg-white border border-gray-200 rounded-lg hover:text-red-500 hover:border-red-200 shadow-sm transition-all">
      Xóa lọc
    </button>
  </div>
</div>

<!-- Bảng dữ liệu -->
<div class="relative rounded-2xl overflow-x-auto p-6 bg-gray-50 font-sans">
  <% if (logs && logs.length > 0) { %>
  <table class="w-full text-sm text-left text-gray-700 border-separate" style="border-spacing: 0 10px;">
    <thead class="text-xs text-gray-400 uppercase tracking-widest font-semibold bg-white shadow-sm">
      <tr>
        <th class="px-4 py-4 rounded-l-2xl border-y border-l border-gray-100">#</th>
        <th class="px-4 py-4 border-y border-gray-100">ADMIN</th>
        <th class="px-4 py-4 border-y border-gray-100">HÀNH ĐỘNG</th>
        <th class="px-4 py-4 border-y border-gray-100">CHI TIẾT</th>
        <th class="px-4 py-4 border-y border-gray-100 text-center">ĐỐI TƯỢNG</th>
        <th class="px-4 py-4 border-y border-r border-gray-100 rounded-r-2xl text-center">THỜI GIAN</th>
      </tr>
    </thead>
    <tbody>
      <% logs.forEach((log, i) => { %>
        <%
          const ACTION_LABELS = {
            admin_login:        'Đăng nhập',
            admin_logout:       'Đăng xuất',
            create_course:      'Tạo khóa học',
            update_course:      'Cập nhật khóa học',
            delete_course:      'Xóa khóa học',
            restore_course:     'Khôi phục khóa học',
            update_curriculum:  'Cập nhật chương trình',
            delete_review:      'Xóa đánh giá',
            create_unit:        'Tạo chương',
            update_unit:        'Cập nhật chương',
            delete_unit:        'Xóa chương',
            restore_unit:       'Khôi phục chương',
            create_lesson:      'Tạo bài học',
            update_lesson:      'Cập nhật bài học',
            delete_lesson:      'Xóa bài học',
            restore_lesson:     'Khôi phục bài học',
            hide_comment:       'Ẩn bình luận',
            restore_comment:    'Khôi phục bình luận',
            delete_comment:     'Xóa bình luận',
            accept_report:      'Chấp nhận báo cáo',
            reject_report:      'Từ chối báo cáo',
            update_email:       'Đổi email',
            update_password:    'Đổi mật khẩu',
            update_settings:    'Cập nhật cài đặt',
          };

          const action = (log.action || '').toLowerCase();
          const actionLabel = ACTION_LABELS[log.action] || log.action;

          let badgeClass = 'bg-gray-100 text-gray-600 border-gray-200';
          let dotClass = 'bg-gray-400';
          if (action.includes('login') || action.includes('logout') || action.includes('auth')) {
            badgeClass = 'bg-purple-50 text-purple-700 border-purple-200';
            dotClass = 'bg-purple-500';
          } else if (action.includes('create') || action.includes('add')) {
            badgeClass = 'bg-green-50 text-green-700 border-green-200';
            dotClass = 'bg-green-500';
          } else if (action.includes('delete') || action.includes('remove')) {
            badgeClass = 'bg-red-50 text-red-700 border-red-200';
            dotClass = 'bg-red-500';
          } else if (action.includes('update') || action.includes('edit') || action.includes('change')) {
            badgeClass = 'bg-blue-50 text-blue-700 border-blue-200';
            dotClass = 'bg-blue-500';
          } else if (action.includes('restore')) {
            badgeClass = 'bg-teal-50 text-teal-700 border-teal-200';
            dotClass = 'bg-teal-500';
          } else if (action.includes('hide')) {
            badgeClass = 'bg-orange-50 text-orange-700 border-orange-200';
            dotClass = 'bg-orange-500';
          } else if (action.includes('accept') || action.includes('reject')) {
            badgeClass = 'bg-sky-50 text-sky-700 border-sky-200';
            dotClass = 'bg-sky-500';
          }

          const createdAt = new Date(log.createdAt);
          const dateStr = createdAt.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
          const timeStr = createdAt.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        %>
        <tr class="bg-white rounded-2xl hover:shadow-md transition-all duration-200">
          <td class="px-4 py-4 rounded-s-2xl border-y border-s border-gray-100 text-gray-400 font-mono text-xs">
            #<%= log.id %>
          </td>
          <td class="px-4 py-4 border-y border-gray-100">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xs flex-shrink-0">
                <%= (log.adminUsername || '?')[0].toUpperCase() %>
              </div>
              <span class="font-semibold text-gray-800 text-sm"><%= log.adminUsername || '<em class="text-gray-400">Đã xóa</em>' %></span>
            </div>
          </td>
          <td class="px-4 py-4 border-y border-gray-100">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold border <%= badgeClass %>">
              <span class="w-1.5 h-1.5 mr-1.5 rounded-full <%= dotClass %>"></span>
              <%= actionLabel %>
            </span>
          </td>
          <td class="px-4 py-4 border-y border-gray-100 max-w-xs">
            <% if (log.detail) { %>
              <p class="text-gray-500 text-xs truncate" title="<%= log.detail %>"><%= log.detail %></p>
            <% } else { %>
              <span class="text-gray-300 text-xs italic">—</span>
            <% } %>
          </td>
          <td class="px-4 py-4 border-y border-gray-100 text-center">
            <% if (log.targetUserId) { %>
              <span class="text-xs font-mono text-indigo-500 bg-indigo-50 px-2 py-0.5 rounded-full border border-indigo-100">
                User #<%= log.targetUserId %>
              </span>
            <% } else { %>
              <span class="text-gray-300 text-xs">—</span>
            <% } %>
          </td>
          <td class="px-4 py-4 rounded-e-2xl border-y border-e border-gray-100 text-center">
            <p class="text-gray-700 text-xs font-semibold"><%= timeStr %></p>
            <p class="text-gray-400 text-xs"><%= dateStr %></p>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- Phân trang -->
  <nav class="mt-8 w-full flex flex-col items-center justify-center space-y-4">
    <% if (pagination.totalPages > 1) { %>
    <%
      function getPageUrl(p) {
        const urlParams = new URLSearchParams(query);
        urlParams.set('page', p);
        return '?' + urlParams.toString();
      }
    %>
    <ul class="flex items-center space-x-2 text-sm">
      <li>
        <% if (pagination.page > 1) { %>
        <a href="<%= getPageUrl(pagination.page - 1) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
        </a>
        <% } else { %>
        <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 text-gray-300 cursor-not-allowed">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
        </div>
        <% } %>
      </li>
      <% for (let p = 1; p <= pagination.totalPages; p++) { %>
        <li>
          <% if (p === pagination.page) { %>
          <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-600 text-white font-bold shadow-lg shadow-indigo-100"><%= p %></span>
          <% } else { %>
          <a href="<%= getPageUrl(p) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-600 font-semibold hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm"><%= p %></a>
          <% } %>
        </li>
      <% } %>
      <li>
        <% if (pagination.page < pagination.totalPages) { %>
        <a href="<%= getPageUrl(pagination.page + 1) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
        </a>
        <% } else { %>
        <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 text-gray-300 cursor-not-allowed">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
        </div>
        <% } %>
      </li>
    </ul>
    <span class="text-xs font-semibold text-gray-400">
      Trang <%= pagination.page %> / <%= pagination.totalPages %> (<%= pagination.totalItems %> bản ghi)
    </span>
    <% } %>
  </nav>

  <% } else { %>
  <div class="flex flex-col items-center justify-center py-16 bg-white rounded-2xl border border-gray-100 shadow-sm">
    <svg class="w-20 h-20 text-gray-200 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <h3 class="text-lg font-bold text-gray-800 mb-1">Không có nhật ký nào</h3>
    <p class="text-gray-500 font-medium text-sm">Chưa có hoạt động nào được ghi lại hoặc không tìm thấy kết quả phù hợp.</p>
  </div>
  <% } %>
</div>

<script>
  // Submit form tìm kiếm
  document.getElementById('searchForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const url = new URL(window.location.href);
    const q = document.getElementById('searchInput').value.trim();
    if (q) url.searchParams.set('q', q);
    else url.searchParams.delete('q');
    url.searchParams.delete('page');
    window.location.href = url.toString();
  });

  // Thay đổi bộ lọc admin/thời gian tự động áp dụng
  ['filterAdmin', 'filterTime'].forEach(id => {
    document.getElementById(id).addEventListener('change', () => {
      const url = new URL(window.location.href);
      const admin = document.getElementById('filterAdmin').value;
      const time = document.getElementById('filterTime').value;
      if (admin) url.searchParams.set('adminId', admin);
      else url.searchParams.delete('adminId');
      if (time) url.searchParams.set('time', time);
      else url.searchParams.delete('time');
      url.searchParams.delete('page');
      window.location.href = url.toString();
    });
  });

  // Xóa tất cả bộ lọc
  document.getElementById('btnClear').addEventListener('click', () => {
    window.location.href = window.location.pathname;
  });
</script>
