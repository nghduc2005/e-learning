<div class="flex items-center justify-between mb-8">
      <p class="text-sm text-gray-500 mt-1">Chỉnh sửa thông tin khóa học: <strong><%= course.name %></strong>.</p>
  <a href="javascript:void(0)" onclick="window.opener ? window.close() : history.back()" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 flex items-center transition-colors">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Quay lại danh sách
  </a>
</div>
<div class="relative rounded-2xl overflow-x-auto p-6 bg-gray-50 font-sans">
    <form id="editCourseForm" enctype="multipart/form-data" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden" action="/admin/course/edit/<%= course.id %>" method="POST">
      <div class="p-8 space-y-6">
          
          <div class="grid grid-cols-1 gap-2">
              <label for="title" class="text-sm font-bold text-gray-700 uppercase tracking-wider">Tên khóa học <span class="text-red-600">*</span></label>
              <input type="text" id="title" name="title" 
                  value="<%= course.name %>"
                  placeholder="Ví dụ: Lập trình C++"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all placeholder:text-gray-400 text-gray-700">
            <div id="title-error"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                  <label for="status" class="text-sm font-bold text-gray-700 uppercase tracking-wider">Trạng thái <span class="text-red-600">*</span></label>
                  <select id="status" name="status" 
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all text-gray-700 appearance-none bg-no-repeat bg-[right_1rem_center] bg-[length:1em_1em]"
                      style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 fill=%22none%22 viewBox=%220 0 24 24%22 stroke=%22%236b7280%22%3E%3Cpath stroke-linecap=%22round%22 stroke-linejoin=%22round%22 stroke-width=%222%22 d=%22M19 9l-7 7-7-7%22/%3E%3C/svg%3E');">
                      <option value="hidden" <%= course.status === 'hidden' ? 'selected' : '' %>>Ẩn</option>
                      <option value="locked" <%= course.status === 'locked' ? 'selected' : '' %>>Khóa</option>
                      <option value="active" <%= course.status === 'active' ? 'selected' : '' %>>Hoạt động</option>
                  </select>
                  <div id="status-error"></div>
              </div>

              <div class="grid grid-cols-1">
                <label class="text-sm font-bold text-gray-700 uppercase tracking-wider">Banner khóa học</label>
                <div class="relative group">
                    <input type="file" id="banner" name="banner" accept="image/*"
                        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                    
                    <div id="dropzoneContent" class="w-full px-4 py-3 rounded-xl border border-dashed border-gray-300 group-hover:border-indigo-400 group-hover:bg-indigo-50 transition-all flex items-center justify-center text-gray-500 <%= course.banner ? 'hidden' : '' %>">
                        <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                        <span class="text-sm font-medium">Tải ảnh lên hoặc kéo thả (để thay đổi)</span>
                    </div>
            
                    <div id="previewContainer" class="<%= course.banner ? '' : 'hidden' %> mt-2 relative z-20 rounded-xl overflow-hidden border border-gray-200">
                      <img id="imagePreview" src="<%= course.banner || '#' %>" alt="Preview" class="w-full h-48 object-cover">
                      <button type="button" id="removeImage" class="absolute top-2 right-2 bg-red-500 text-white p-1.5 rounded-full hover:bg-red-600 shadow-lg transition-all">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                      </button>
                  </div>
                </div>
                <div id="banner-error"></div>
            </div>

            <div class="grid grid-cols-1 gap-2 md:col-span-2">
              <label class="text-sm font-bold text-gray-700 uppercase tracking-wider">Mô tả khóa học</label>
              
              <div class="quill-wrapper border border-gray-200 rounded-xl overflow-hidden focus-within:ring-4 focus-within:ring-indigo-50 focus-within:border-indigo-500 transition-all">
                  <div id="toolbar" class="border-none bg-gray-50 border-b border-gray-200">
                      <span class="ql-formats">
                          <button class="ql-bold"></button>
                          <button class="ql-italic"></button>
                          <button class="ql-underline"></button>
                      </span>
                      <span class="ql-formats">
                          <button class="ql-list" value="ordered"></button>
                          <button class="ql-list" value="bullet"></button>
                      </span>
                      <span class="ql-formats">
                          <button class="ql-link"></button>
                          <button class="ql-image"></button>
                      </span>
                      <span class="ql-formats">
                          <button class="ql-clean"></button>
                      </span>
                  </div>
                  
                  <div id="editor" style="height: 250px;" class="border-none text-gray-700">
                      <!-- Nội dung description sẽ được JS đổ vào đây -->
                  </div>
              </div>
              <input type="hidden" name="description" id="description">
              <div id="description-error"></div>
          </div>
      </div>

      <div class="px-8 py-5 flex items-center justify-end space-x-4 border-t border-gray-100">
        <button data-modal-target="popup-modal" data-modal-toggle="popup-modal" type="button" class="px-6 py-2.5 text-sm font-semibold text-gray-600 hover:text-red-600 transition-colors">
          Hủy bỏ
      </button>
      
      <div id="popup-modal" tabindex="-1" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-[60] justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full bg-gray-900/50 backdrop-blur-sm">
          <div class="relative p-4 w-full max-w-md max-h-full">
              <div class="relative bg-white rounded-2xl shadow-xl border border-gray-100">
                  <button type="button" class="absolute top-3 end-2.5 text-gray-400 bg-transparent hover:bg-gray-100 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center" data-modal-hide="popup-modal">
                      <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                      </svg>
                  </button>
      
                  <div class="p-6 text-center">
                      <div class="mx-auto mb-4 w-14 h-14 bg-red-50 rounded-full flex items-center justify-center">
                          <svg class="text-red-600 w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                      </div>
                      <h3 class="mb-2 text-lg font-bold text-gray-900">Xác nhận hủy?</h3>
                      <p class="mb-6 text-sm text-gray-500">Mọi thông tin chỉnh sửa sẽ không được lưu lại. Bạn có chắc chắn muốn quay lại danh sách?</p>
                      
                      <div class="flex items-center space-x-3 justify-center">
                          <a href="javascript:void(0)" onclick="window.opener ? window.close() : history.back()" class="text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-bold rounded-xl text-sm inline-flex items-center px-5 py-2.5 text-center transition-all">
                              Có
                          </a>
                          <button data-modal-hide="popup-modal" type="button" class="text-gray-500 bg-white hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-indigo-300 rounded-xl border border-gray-200 text-sm font-bold px-5 py-2.5 hover:text-gray-900 transition-all">
                              Không
                          </button>
                      </div>
                  </div>
              </div>
          </div>
      </div>
          <button type="submit" 
              class="inline-flex items-center px-8 py-2.5 text-sm font-bold text-center text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 focus:ring-4 focus:outline-none focus:ring-indigo-300 shadow-lg shadow-indigo-100 transform active:scale-95 transition-all">
              Cập nhật khóa học
          </button>
      </div>
  </form>
</div>
<%- include('../layouts/components/lazyload.ejs')%>

<script>
    // Khởi tạo Quill Editor (Giả sử bạn dùng thư viện Quill tương tự courseCreate)
    // Để đổ nội dung description cũ vào editor, bạn có thể truyền biến course.description
    window.INITIAL_COURSE_DESC = `<%- course.description || '' %>`;
</script>
<script src="/admin/assets/js/courseEdit.js"></script>


