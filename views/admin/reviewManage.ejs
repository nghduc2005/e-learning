<%# ── Summary cards ───────────────────────────────────────────────────────── %>
<p class="text-sm text-gray-500 -mt-4 mb-4">Xem và quản lý đánh giá của học viên đối với khóa học.</p>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
        <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= reviews.length %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Tổng đánh giá</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
      </svg>
    </div>
    <div>
      <div class="flex items-center gap-1.5">
        <p class="text-2xl font-bold text-gray-800"><%= avgRating %></p>
        <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
        </svg>
      </div>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Điểm trung bình</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= reviews.filter(r => r.ratingNum === 5).length %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Đánh giá 5 sao</p>
    </div>
  </div>
</div>

<%# ── Table ───────────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <% if (reviews.length === 0) { %>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <svg class="w-16 h-16 text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
      </svg>
      <p class="text-gray-800 font-semibold">Chưa có đánh giá nào</p>
      <p class="text-sm text-gray-400 mt-1">Các đánh giá của học viên sẽ hiện ở đây.</p>
    </div>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left">
      <thead>
        <tr class="text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
          <th class="px-6 py-4 pl-6 w-1/4">Người đánh giá</th>
          <th class="px-6 py-4 text-center w-36">Điểm</th>
          <th class="px-6 py-4">Nội dung</th>
          <th class="px-6 py-4 text-center w-36">Thời gian</th>
          <th class="px-6 py-4 text-center w-24">Thao tác</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% for (const r of reviews) { %>
        <tr class="hover:bg-gray-50/60 transition-colors" id="review-row-<%= r.id %>">
          <%# Reviewer %>
          <td class="px-6 py-4">
            <div class="flex items-center gap-2.5">
              <% if (r.avatar) { %>
                <img src="<%= r.avatar %>" class="w-8 h-8 rounded-full object-cover flex-shrink-0" alt="">
              <% } else { %>
                <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-bold text-amber-600"><%= r.username.charAt(0).toUpperCase() %></span>
                </div>
              <% } %>
              <span class="font-medium text-gray-800 text-xs truncate max-w-[110px]"><%= r.username %></span>
            </div>
          </td>

          <%# Rating stars %>
          <td class="px-6 py-4 text-center">
            <div class="flex items-center justify-center gap-0.5">
              <% for (let i = 1; i <= 5; i++) { %>
                <svg class="w-4 h-4 <%= i <= r.ratingNum ? 'text-amber-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
                </svg>
              <% } %>
            </div>
            <span class="text-xs font-bold text-gray-500 mt-1 block"><%= r.ratingNum %>/5</span>
          </td>

          <%# Content %>
          <td class="px-6 py-4">
            <% if (r.content) { %>
              <p class="text-sm text-gray-700 line-clamp-2"><%= r.content %></p>
            <% } else { %>
              <p class="text-xs text-gray-300 italic">Không có nội dung</p>
            <% } %>
          </td>

          <%# Date %>
          <td class="px-6 py-4 text-center">
            <span class="text-xs text-gray-400 whitespace-nowrap"><%= r.createdAt %></span>
          </td>

          <%# Actions %>
          <td class="px-6 py-4 text-center">
            <button
              onclick="confirmDeleteReview('<%= r.id %>')"
              title="Xóa đánh giá"
              class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-red-400 text-red-400 hover:bg-red-400 hover:text-white transition-all shadow-sm mx-auto">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
              </svg>
            </button>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%# ── Confirm delete modal ────────────────────────────────────────────────── %>
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-base font-bold text-gray-800">Xóa đánh giá</h3>
        <p class="text-xs text-gray-500 mt-0.5">Hành động này không thể hoàn tác.</p>
      </div>
    </div>
    <p class="text-sm text-gray-600 mb-6">Đánh giá sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
    <div class="flex gap-3 justify-end">
      <button onclick="closeDeleteModal()"
              class="px-4 py-2 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
        Hủy
      </button>
      <button id="confirmDeleteBtn"
              class="px-4 py-2 rounded-xl bg-red-500 text-white text-sm font-bold hover:bg-red-600 transition-colors shadow-md shadow-red-100">
        Xóa vĩnh viễn
      </button>
    </div>
  </div>
</div>

<%# ── Toast notification ──────────────────────────────────────────────────── %>
<div id="toast"
     class="fixed bottom-6 right-6 z-50 hidden items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white transition-all">
</div>

<script>
  let pendingDeleteId = null;

  function confirmDeleteReview(reviewId) {
    pendingDeleteId = reviewId;
    document.getElementById('deleteModal').classList.remove('hidden');
    document.getElementById('deleteModal').classList.add('flex');
  }

  function closeDeleteModal() {
    pendingDeleteId = null;
    document.getElementById('deleteModal').classList.add('hidden');
    document.getElementById('deleteModal').classList.remove('flex');
  }

  document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    try {
      const res = await axios.post(`/admin/course/review/${pendingDeleteId}/delete`);
      if (res.data.ok) {
        closeDeleteModal();
        showToast('Đã xóa đánh giá', 'error');
        setTimeout(() => location.reload(), 800);
      }
    } catch {
      showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
    }
  });

  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    const colors = {
      success: 'bg-emerald-500',
      warn:    'bg-amber-500',
      error:   'bg-red-500',
    };
    const icons = {
      success: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4.5 12.75 6 6 9-13.5"/></svg>',
      warn:    '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>',
      error:   '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/></svg>',
    };
    toast.className = `fixed bottom-6 right-6 z-50 flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white transition-all ${colors[type]}`;
    toast.innerHTML = icons[type] + message;
    toast.classList.remove('hidden');
    setTimeout(() => { toast.classList.add('hidden'); }, 3000);
  }

  document.getElementById('deleteModal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
  });
</script>
