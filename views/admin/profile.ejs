<p class="text-sm text-gray-500 -mt-4 mb-6">Quản lý thông tin tài khoản và bảo mật của bạn.</p>

<!-- Flash message -->
<% if (typeof flash !== 'undefined' && flash) { %>
<div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
  <%= flash.type === 'success'
    ? 'bg-green-50 border border-green-200 text-green-700'
    : 'bg-red-50 border border-red-200 text-red-700' %>">
  <% if (flash.type === 'success') { %>
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
  <% } else { %>
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"/>
    </svg>
  <% } %>
  <%= flash.message %>
</div>
<% } %>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

  <!-- Cột trái: Thông tin tài khoản -->
  <div class="xl:col-span-1 space-y-6">

    <!-- Card avatar + info -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-indigo-600 text-white text-2xl font-bold shadow-md shadow-indigo-200 mb-4">
        <%= admin.username.substring(0, 2).toUpperCase() %>
      </div>
      <h3 class="text-lg font-bold text-gray-800"><%= admin.username %></h3>
      <p class="text-sm text-gray-500 mt-1"><%= admin.email %></p>
      <span class="mt-3 inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold
        <%= admin.status === 'active' ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' %>">
        <span class="w-1.5 h-1.5 rounded-full <%= admin.status === 'active' ? 'bg-green-500' : 'bg-red-500' %>"></span>
        <%= admin.status === 'active' ? 'Đang hoạt động' : 'Đã bị khóa' %>
      </span>

      <div class="mt-5 pt-5 border-t border-gray-100 space-y-3 text-left">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Tên đăng nhập</p>
            <p class="text-sm font-medium text-gray-700"><%= admin.username %></p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Ngày tạo</p>
            <p class="text-sm font-medium text-gray-700">
              <%= new Date(admin.createdAt).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' }) %>
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Cột phải: Form chỉnh sửa -->
  <div class="xl:col-span-2 space-y-6">

    <!-- Form đổi email -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-indigo-50 flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-bold text-gray-800">Cập nhật Email</h3>
          <p class="text-xs text-gray-400 mt-0.5">Thay đổi địa chỉ email đăng nhập</p>
        </div>
      </div>
      <form action="/admin/profile/email" method="POST" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email mới</label>
          <input type="email" name="email" required placeholder="example@email.com"
            class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Mật khẩu hiện tại <span class="text-red-400">*</span></label>
          <input type="password" name="currentPassword" required placeholder="Xác nhận bằng mật khẩu hiện tại"
            class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all">
        </div>
        <div class="flex justify-end pt-2">
          <button type="submit"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-all shadow-sm shadow-indigo-200 hover:-translate-y-0.5 active:translate-y-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Cập nhật email
          </button>
        </div>
      </form>
    </div>

    <!-- Form đổi mật khẩu -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-orange-50 flex items-center justify-center">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-bold text-gray-800">Đổi mật khẩu</h3>
          <p class="text-xs text-gray-400 mt-0.5">Cập nhật mật khẩu để bảo vệ tài khoản</p>
        </div>
      </div>
      <form action="/admin/profile/password" method="POST" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Mật khẩu hiện tại <span class="text-red-400">*</span></label>
          <input type="password" name="currentPassword" required placeholder="Nhập mật khẩu hiện tại"
            class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all">
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Mật khẩu mới <span class="text-red-400">*</span></label>
            <input type="password" name="newPassword" id="newPassword" required placeholder="Tối thiểu 6 ký tự"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Xác nhận mật khẩu <span class="text-red-400">*</span></label>
            <input type="password" name="confirmPassword" id="confirmPassword" required placeholder="Nhập lại mật khẩu mới"
              class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-all">
          </div>
        </div>
        <div id="passwordMatchMsg" class="hidden text-xs text-red-500">Mật khẩu xác nhận không khớp.</div>
        <div class="flex justify-end pt-2">
          <button type="submit" id="changePwBtn"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-orange-500 hover:bg-orange-400 text-white text-sm font-semibold rounded-xl transition-all shadow-sm shadow-orange-200 hover:-translate-y-0.5 active:translate-y-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            Đổi mật khẩu
          </button>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
  const newPw = document.getElementById('newPassword');
  const confirmPw = document.getElementById('confirmPassword');
  const msg = document.getElementById('passwordMatchMsg');
  const btn = document.getElementById('changePwBtn');

  function checkMatch() {
    if (confirmPw.value && newPw.value !== confirmPw.value) {
      msg.classList.remove('hidden');
      btn.disabled = true;
      btn.classList.add('opacity-60', 'cursor-not-allowed');
    } else {
      msg.classList.add('hidden');
      btn.disabled = false;
      btn.classList.remove('opacity-60', 'cursor-not-allowed');
    }
  }

  newPw.addEventListener('input', checkMatch);
  confirmPw.addEventListener('input', checkMatch);
</script>
