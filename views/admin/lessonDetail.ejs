<p class="text-sm text-gray-500 -mt-4 mb-4">Xem thông tin chi tiết của chương học.</p>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
        <div>
        </div>
        <div class="flex space-x-3">
            <a href="/admin/lesson/<%= lesson.id %>/comments" class="inline-flex items-center px-4 py-2 text-sm font-bold text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition-all">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Bình luận
            </a>
            <a href="/admin/lesson/edit/<%= lesson.id %>" class="inline-flex items-center px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition-all">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="space-y-6 lg:col-span-1">
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Thông tin hệ thống</h3>
                <div class="space-y-4">
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Trạng thái</span>
                        <% const statusColors = { active: 'bg-green-100 text-green-700', locked: 'bg-yellow-100 text-yellow-700', hidden: 'bg-gray-100 text-gray-700' }; %>
                        <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= statusColors[lesson.status] || 'bg-gray-100 text-gray-700' %>">
                            <%= lesson.status === 'active' ? 'Hoạt động' : lesson.status === 'locked' ? 'Khóa' : 'Ẩn' %>
                        </span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Hình thức</span>
                        <span class="text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded font-bold uppercase text-xs">
                            <%= lesson.learnMode === 'video' ? 'Video' : 'Bài viết' %>
                        </span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Điểm qua môn</span>
                        <span class="text-gray-800 font-bold"><%= lesson.passScore || 0 %> câu</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Ngày tạo</span>
                        <span class="text-gray-800 font-bold"><%= lesson.createdAt ? new Date(lesson.createdAt).toLocaleString('vi-VN') : 'N/A' %></span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Cập nhật</span>
                        <span class="text-gray-800 font-bold"><%= lesson.updatedAt ? new Date(lesson.updatedAt).toLocaleString('vi-VN') : 'N/A' %></span>
                    </div>
                </div>
            </div>

            <% if (lesson.documents && lesson.documents.length > 0) { %>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Tài liệu đính kèm</h3>
                <div class="space-y-3">
                    <% lesson.documents.forEach(doc => { %>
                        <a href="<%= doc.url %>" target="_blank" class="flex items-center p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
                            <div class="mr-3">
                                <% if (doc.fileType === 'pdf') { %>
                                    <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                                <% } else { %>
                                    <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                <% } %>
                            </div>
                            <div class="overflow-hidden">
                                <p class="text-sm font-medium text-gray-800 truncate"><%= doc.name %></p>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
            <% } %>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
                <div class="mb-6">
                    <h4 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Tên bài học</h4>
                    <h1 class="text-3xl font-black text-gray-900 leading-tight"><%= lesson.name %></h1>
                </div>

                <% if (lesson.content) { %>
                <div class="mt-6 p-4 bg-gray-50 rounded-2xl border border-gray-100">
                    <h4 class="text-sm font-bold text-gray-800 uppercase mb-3">Nội dung chính</h4>
                    <% if (lesson.learnMode === 'video') { %>
                        <a href="<%= lesson.content %>" target="_blank" class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800">
                            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            Xem Video Bài Giảng
                        </a>
                    <% } else { %>
                        <a href="<%= lesson.content %>" target="_blank" class="inline-flex items-center text-sm font-medium text-emerald-600 hover:text-emerald-800">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                            Đọc Tài Liệu Bài Giảng
                        </a>
                    <% } %>
                </div>
                <% } %>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-black text-gray-900 italic">Danh sách câu hỏi (<%= lesson.questionsList ? lesson.questionsList.length : 0 %>)</h3>
                </div>
                
                <% if (!lesson.questionsList || lesson.questionsList.length === 0) { %>
                    <div class="flex flex-col items-center justify-center py-12 border-2 border-dashed border-gray-100 rounded-3xl">
                        <p class="text-sm text-gray-400 italic">Bài học này chưa có câu hỏi nào.</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4">
                        <% lesson.questionsList.forEach((q, idx) => { %>
                            <div class="border border-gray-100 rounded-2xl bg-white shadow-sm overflow-hidden">
                                <button type="button" onclick="this.nextElementSibling.classList.toggle('hidden'); const icon = this.querySelector('.collapse-icon'); icon.classList.toggle('rotate-180');" class="w-full flex items-center justify-between p-5 bg-gray-50/50 hover:bg-gray-100/50 transition-colors outline-none text-left">
                                    <div class="flex items-start space-x-3">
                                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-sm">
                                            <%= idx + 1 %>
                                        </div>
                                        <div class="flex-grow pt-1 pr-4">
                                            <h4 class="text-sm font-bold text-gray-900 leading-relaxed line-clamp-2"><%= q.content %></h4>
                                        </div>
                                    </div>
                                    <svg class="collapse-icon w-5 h-5 text-gray-400 transform transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                
                                <div class="hidden border-t border-gray-50 p-5">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                        <% q.answers.forEach((ans, ansIdx) => { %>
                                            <div class="flex items-center p-3 rounded-xl border <%= q.correctAnswer === ansIdx ? 'bg-green-50 border-green-200' : 'bg-white border-gray-100' %>">
                                                <div class="flex-shrink-0 w-5 h-5 rounded-full border-2 <%= q.correctAnswer === ansIdx ? 'border-green-500 bg-green-500' : 'border-gray-300' %> flex items-center justify-center mr-3">
                                                    <% if (q.correctAnswer === ansIdx) { %>
                                                        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                                    <% } %>
                                                </div>
                                                <span class="text-sm <%= q.correctAnswer === ansIdx ? 'text-green-800 font-bold' : 'text-gray-600' %>"><%= ans %></span>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
