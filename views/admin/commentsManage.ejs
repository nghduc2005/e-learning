<p class="text-sm text-gray-500 -mt-4 mb-4">Xem toàn bộ bình luận, lọc theo trạng thái báo cáo hoặc đã ẩn; xử lý báo cáo bằng cách ẩn hoặc xóa vĩnh viễn.</p>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= allComments.length %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Tổng bình luận</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-red-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3l1.664 1.664M21 21l-1.5-1.5m-5.485-1.242L12 17.25 4.5 21V8.742m.164-4.078a2.15 2.15 0 0 1 1.743-1.342 48.507 48.507 0 0 1 11.186 0c1.1.128 1.907 1.077 1.907 2.185V19.5M4.664 4.664 19.5 19.5"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= hiddenCount %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Đã ẩn</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= reportedCount %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Báo cáo chờ xử lý</p>
    </div>
  </div>
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <div class="flex flex-wrap border-b border-gray-100 px-4 sm:px-6 gap-1">
    <a href="?filter=all"
       class="py-4 px-3 text-sm font-semibold border-b-2 transition-colors <%= filter === 'all' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Tất cả
    </a>
    <a href="?filter=reported"
       class="py-4 px-3 text-sm font-semibold border-b-2 transition-colors inline-flex items-center gap-2 <%= filter === 'reported' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Bị báo cáo
      <% if (reportedCount > 0) { %>
        <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-600"><%= reportedCount %></span>
      <% } %>
    </a>
    <a href="?filter=hidden"
       class="py-4 px-3 text-sm font-semibold border-b-2 transition-colors <%= filter === 'hidden' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Đã ẩn
      <% if (hiddenCount > 0) { %>
        <span class="ml-1 px-2 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-600"><%= hiddenCount %></span>
      <% } %>
    </a>
  </div>

  <% if (filter === 'reported') { %>
  <div class="p-6">
    <% if (!pendingReports.length) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <p class="text-gray-800 font-semibold">Không có báo cáo đang chờ</p>
        <p class="text-sm text-gray-400 mt-1">Mọi báo cáo đã được xử lý hoặc chưa có báo cáo nào.</p>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
            <th class="pb-3 pl-2">Khóa học / Bài học</th>
            <th class="pb-3">Bình luận</th>
            <th class="pb-3">Người báo cáo</th>
            <th class="pb-3">Lý do</th>
            <th class="pb-3 text-center whitespace-nowrap">Thời gian</th>
            <th class="pb-3 text-center min-w-[200px]">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const r of pendingReports) { %>
          <tr class="hover:bg-gray-50/60" id="global-report-<%= r.reportId %>">
            <td class="py-4 pl-2">
              <p class="font-medium text-gray-800 text-xs"><%= r.courseName %></p>
              <p class="text-gray-400 text-xs mt-0.5"><%= r.lessonName %></p>
            </td>
            <td class="py-4 pr-3 max-w-xs">
              <p class="text-xs text-gray-400 mb-0.5">Tác giả: <span class="font-medium text-gray-600"><%= r.commentAuthor %></span></p>
              <% if (r.commentDeleted) { %>
                <p class="text-xs text-gray-300 italic">[ Đã ẩn ]</p>
              <% } else { %>
                <p class="text-sm text-gray-700 line-clamp-2"><%= r.commentContent %></p>
              <% } %>
            </td>
            <td class="py-4">
              <span class="text-xs font-medium text-gray-700"><%= r.reporterName %></span>
            </td>
            <td class="py-4 pr-2"><p class="text-sm text-gray-600 line-clamp-2"><%= r.reason %></p></td>
            <td class="py-4 text-center whitespace-nowrap text-xs text-gray-400"><%= r.reportedAt %></td>
            <td class="py-4">
              <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-1.5">
                <button type="button"
                  onclick="globalReportAction('hide', '<%= r.reportId %>')"
                  class="px-2.5 py-1.5 rounded-lg bg-white border border-emerald-500 text-emerald-600 text-xs font-semibold hover:bg-emerald-500 hover:text-white transition-all">
                  Ẩn bình luận
                </button>
                <button type="button"
                  onclick="globalReportAction('delete', '<%= r.reportId %>')"
                  class="px-2.5 py-1.5 rounded-lg bg-white border border-red-400 text-red-500 text-xs font-semibold hover:bg-red-500 hover:text-white transition-all">
                  Xóa vĩnh viễn
                </button>
                <button type="button"
                  onclick="globalReportAction('reject', '<%= r.reportId %>')"
                  class="px-2.5 py-1.5 rounded-lg bg-white border border-gray-300 text-gray-600 text-xs font-semibold hover:bg-gray-50">
                  Từ chối
                </button>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } else { %>
  <% const rows = filter === 'hidden' ? allComments.filter(function(c){ return c.isDeleted; }) : allComments; %>
  <div class="p-6">
    <% if (!rows.length) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <p class="text-gray-800 font-semibold"><%= filter === 'hidden' ? 'Không có bình luận đã ẩn' : 'Chưa có bình luận' %></p>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
            <th class="pb-3 pl-2">Người dùng</th>
            <th class="pb-3">Nội dung</th>
            <th class="pb-3">Khóa học / Bài</th>
            <th class="pb-3 text-center">Báo cáo</th>
            <th class="pb-3 text-center">Trạng thái</th>
            <th class="pb-3 text-center whitespace-nowrap">Thời gian</th>
            <th class="pb-3 text-center">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const c of rows) { %>
          <tr class="hover:bg-gray-50/60" id="global-comment-<%= c.id %>">
            <td class="py-4 pl-2">
              <div class="flex items-center gap-2">
                <% if (c.avatar) { %>
                  <img src="<%= c.avatar %>" class="w-8 h-8 rounded-full object-cover" alt="">
                <% } else { %>
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center">
                    <span class="text-xs font-bold text-indigo-600"><%= c.username.charAt(0).toUpperCase() %></span>
                  </div>
                <% } %>
                <span class="font-medium text-gray-800 text-xs truncate max-w-[100px]"><%= c.username %></span>
              </div>
            </td>
            <td class="py-4 pr-3 max-w-xs">
              <% if (c.isReply) { %>
                <span class="inline-block mb-1 px-2 py-0.5 text-[10px] font-bold uppercase text-violet-600 bg-violet-50 rounded-full">Trả lời</span>
              <% } %>
              <% if (c.isDeleted) { %>
                <p class="text-xs text-gray-300 italic">[ Nội dung không hiển thị ]</p>
              <% } else { %>
                <p class="text-sm text-gray-700 line-clamp-2"><%= c.content %></p>
              <% } %>
            </td>
            <td class="py-4">
              <p class="text-xs font-medium text-gray-700"><%= c.courseName %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= c.lessonName %></p>
            </td>
            <td class="py-4 text-center">
              <% if (c.pendingReportsCount > 0) { %>
                <span class="inline-flex px-2 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-bold"><%= c.pendingReportsCount %></span>
              <% } else { %>
                <span class="text-gray-300">—</span>
              <% } %>
            </td>
            <td class="py-4 text-center">
              <% if (c.isDeleted) { %>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-red-50 text-red-500 text-xs font-semibold">Đã ẩn</span>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-emerald-50 text-emerald-600 text-xs font-semibold">Hiển thị</span>
              <% } %>
            </td>
            <td class="py-4 text-center text-xs text-gray-400 whitespace-nowrap"><%= c.createdAt %></td>
            <td class="py-4 text-center">
              <div class="flex items-center justify-center gap-1">
                <% if (!c.isDeleted) { %>
                  <button type="button" onclick="globalCommentAction('hide','<%= c.id %>')" title="Ẩn"
                    class="w-8 h-8 flex items-center justify-center rounded-lg border border-amber-400 text-amber-500 hover:bg-amber-400 hover:text-white">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
                  </button>
                <% } else { %>
                  <button type="button" onclick="globalCommentAction('restore','<%= c.id %>')" title="Khôi phục"
                    class="w-8 h-8 flex items-center justify-center rounded-lg border border-emerald-500 text-emerald-500 hover:bg-emerald-500 hover:text-white">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
                  </button>
                <% } %>
                <button type="button" onclick="confirmGlobalDeleteComment('<%= c.id %>')" title="Xóa vĩnh viễn"
                  class="w-8 h-8 flex items-center justify-center rounded-lg border border-red-400 text-red-400 hover:bg-red-400 hover:text-white">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
                </button>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>
</div>

<div id="globalDeleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
    <h3 class="text-base font-bold text-gray-800 mb-2">Xóa vĩnh viễn bình luận?</h3>
    <p class="text-sm text-gray-600 mb-6">Hành động không thể hoàn tác. Các báo cáo liên quan cũng sẽ bị xóa theo.</p>
    <div class="flex gap-3 justify-end">
      <button type="button" onclick="closeGlobalDeleteModal()" class="px-4 py-2 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50">Hủy</button>
      <button type="button" id="globalConfirmDeleteBtn" class="px-4 py-2 rounded-xl bg-red-500 text-white text-sm font-bold hover:bg-red-600">Xóa vĩnh viễn</button>
    </div>
  </div>
</div>

<div id="globalToast" class="fixed bottom-6 right-6 z-50 hidden items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white"></div>

<script>
  let globalPendingDeleteId = null;
  const FILTER = '<%= filter %>';

  function showGlobalToast(message, type) {
    const toast = document.getElementById('globalToast');
    const colors = { success: 'bg-emerald-500', warn: 'bg-amber-500', error: 'bg-red-500' };
    toast.className = `fixed bottom-6 right-6 z-50 flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white ${colors[type] || colors.success}`;
    toast.textContent = message;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3200);
  }

  async function globalCommentAction(action, commentId) {
    const url = action === 'hide'
      ? `/admin/comments/comment/${commentId}/hide`
      : `/admin/comments/comment/${commentId}/restore`;
    try {
      const res = await axios.post(url);
      if (res.data.ok) {
        showGlobalToast(action === 'hide' ? 'Đã ẩn bình luận' : 'Đã khôi phục', action === 'hide' ? 'warn' : 'success');
        setTimeout(() => { window.location.href = '/admin/comments?filter=' + FILTER; }, 600);
      }
    } catch {
      showGlobalToast('Có lỗi xảy ra', 'error');
    }
  }

  function confirmGlobalDeleteComment(id) {
    globalPendingDeleteId = id;
    const m = document.getElementById('globalDeleteModal');
    m.classList.remove('hidden');
    m.classList.add('flex');
  }
  function closeGlobalDeleteModal() {
    globalPendingDeleteId = null;
    const m = document.getElementById('globalDeleteModal');
    m.classList.add('hidden');
    m.classList.remove('flex');
  }

  document.getElementById('globalConfirmDeleteBtn').addEventListener('click', async () => {
    if (!globalPendingDeleteId) return;
    try {
      const res = await axios.post(`/admin/comments/comment/${globalPendingDeleteId}/delete`);
      if (res.data.ok) {
        closeGlobalDeleteModal();
        showGlobalToast('Đã xóa bình luận vĩnh viễn', 'success');
        setTimeout(() => { window.location.href = '/admin/comments?filter=' + FILTER; }, 600);
      }
    } catch {
      showGlobalToast('Có lỗi xảy ra', 'error');
    }
  });

  async function globalReportAction(action, reportId) {
    if (action === 'delete' && !confirm('Xóa vĩnh viễn bình luận này? Không thể hoàn tác.')) return;
    const urls = {
      hide: `/admin/comments/report/${reportId}/accept-hide`,
      delete: `/admin/comments/report/${reportId}/accept-delete`,
      reject: `/admin/comments/report/${reportId}/reject`,
    };
    try {
      const res = await axios.post(urls[action]);
      if (res.data.ok) {
        const msg = action === 'hide' ? 'Đã ẩn bình luận' : action === 'delete' ? 'Đã xóa bình luận vĩnh viễn' : 'Đã từ chối báo cáo';
        showGlobalToast(msg, action === 'reject' ? 'warn' : 'success');
        setTimeout(() => { window.location.href = '/admin/comments?filter=reported'; }, 600);
      }
    } catch {
      showGlobalToast('Có lỗi xảy ra', 'error');
    }
  }

  document.getElementById('globalDeleteModal').addEventListener('click', (e) => {
    if (e.target.id === 'globalDeleteModal') closeGlobalDeleteModal();
  });
</script>
