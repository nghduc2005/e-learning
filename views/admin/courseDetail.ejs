<p class="text-sm text-gray-500 -mt-4 mb-4">Xem thông tin chi tiết của khóa học.</p>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div></div>
    <div class="flex justify-end mb-8">
        <div class="flex space-x-3">
            <a href="/admin/course/<%= course.id %>/reviews" class="inline-flex items-center px-4 py-2 text-sm font-bold text-amber-600 bg-amber-50 rounded-xl hover:bg-amber-100 transition-all">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>
                Đánh giá
            </a>
            <a href="/admin/course/edit/<%= course.id %>" class="inline-flex items-center px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition-all">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Chỉnh sửa
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="space-y-6">
            <div class="bg-white p-2 rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <img src="<%= course.banner %>" 
                     alt="<%= course.name %>" 
                     class="w-full h-48 object-cover rounded-2xl shadow-inner">
            </div>

            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Thông tin hệ thống</h3>
                <div class="space-y-4">
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Trạng thái</span>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold border <%= course.status.bgClass %>">
                            <span class="w-2 h-2 mr-2 rounded-full <%= course.status.dotClass %>"></span>
                            <%= course.status.text %>
                        </span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Ngày tạo</span>
                        <span class="text-gray-800 font-bold"><%= course.createdAt %></span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-500 font-medium">Cập nhật cuối</span>
                        <span class="text-gray-800 font-bold"><%= course.updatedAt || 'N/A' %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
                <div class="mb-6">
                    <h1 class="mt-3 text-3xl font-black text-gray-900 leading-tight"><%= course.name %></h1>
                </div>

                <div class="prose prose-indigo max-w-none">
                    <h4 class="text-sm font-bold text-gray-800 uppercase mb-3">Mô tả khóa học</h4>
                    <p class="text-gray-600 leading-relaxed italic">
                        <%- course.description || 'Chưa có mô tả cho khóa học này.' %>
                    </p>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-black text-gray-900 italic">Cấu trúc nội dung</h3>
                </div>
                <% if (!curriculum || curriculum.length === 0) { %>
                    <div class="flex flex-col items-center justify-center py-12 border-2 border-dashed border-gray-100 rounded-3xl">
                        <p class="text-sm text-gray-400 italic">Khóa học này chưa có chương trình học.</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4">
                        <% curriculum.forEach((unit, idx) => { %>
                            <div class="border border-gray-100 rounded-2xl overflow-hidden bg-white shadow-sm">
                                <button type="button" onclick="this.nextElementSibling.classList.toggle('hidden'); const icon = this.querySelector('svg:last-child'); icon.classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-5 bg-gray-50/50 hover:bg-gray-100/50 transition-colors outline-none">
                                    <div class="flex items-center space-x-4">
                                        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-600 text-white font-bold text-sm"><%= idx + 1 %></div>
                                        <div class="text-left">
                                            <h4 class="font-bold text-gray-900"><%= unit.title %></h4>
                                            <p class="text-xs text-gray-500 mt-0.5"><%= unit.lessons ? unit.lessons.length : 0 %> bài học</p>
                                        </div>
                                    </div>
                                    <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                
                                <div class="hidden border-t border-gray-50">
                                    <% if (!unit.lessons || unit.lessons.length === 0) { %>
                                        <div class="p-4 text-center text-sm text-gray-400 italic bg-white">Chương này chưa có bài học nào.</div>
                                    <% } else { %>
                                        <div class="p-4 space-y-2 bg-white">
                                            <% unit.lessons.forEach((lesson, lIdx) => { %>
                                                <div class="flex items-center justify-between p-3 rounded-xl border border-gray-50 hover:bg-indigo-50/30 transition-colors">
                                                    <div class="flex items-center space-x-3">
                                                        <span class="text-sm font-medium text-gray-400"><%= idx + 1 %>.<%= lIdx + 1 %></span>
                                                        <span class="text-sm font-medium text-gray-700"><%= lesson.title %></span>
                                                        <% if (lesson.status === 'active') { %>
                                                            <span class="ml-2 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-green-700 bg-green-100 rounded-full">Đang hoạt động</span>
                                                        <% } else if (lesson.status === 'locked') { %>
                                                            <span class="ml-2 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-orange-700 bg-orange-100 rounded-full">Khóa</span>
                                                        <% } else if (lesson.status === 'hidden') { %>
                                                            <span class="ml-2 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-gray-700 bg-gray-100 rounded-full">Ẩn</span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>