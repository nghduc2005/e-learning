<%# ── Summary cards ───────────────────────────────────────────────────────── %>
<p class="text-sm text-gray-500 -mt-4 mb-4">Xem và xử lý bình luận, báo cáo của học viên đối với bài học.</p>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= comments.length %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Tổng bình luận</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-red-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3l1.664 1.664M21 21l-1.5-1.5m-5.485-1.242L12 17.25 4.5 21V8.742m.164-4.078a2.15 2.15 0 0 1 1.743-1.342 48.507 48.507 0 0 1 11.186 0c1.1.128 1.907 1.077 1.907 2.185V19.5M4.664 4.664 19.5 19.5"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= comments.filter(c => c.isDeleted).length %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Đã ẩn</p>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm px-6 py-4 flex items-center gap-4">
    <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center">
      <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
      </svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-gray-800"><%= pendingCount %></p>
      <p class="text-xs font-medium text-gray-400 mt-0.5">Báo cáo chờ xử lý</p>
    </div>
  </div>
</div>

<%# ── Tabs ────────────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <div class="flex border-b border-gray-100 px-6">
    <a href="?tab=comments"
       class="py-4 px-2 mr-6 text-sm font-semibold border-b-2 transition-colors <%= tab === 'comments' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Tất cả bình luận
      <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-bold <%= tab === 'comments' ? 'bg-indigo-50 text-indigo-600' : 'bg-gray-100 text-gray-500' %>">
        <%= comments.length %>
      </span>
    </a>
    <a href="?tab=reports"
       class="py-4 px-2 text-sm font-semibold border-b-2 transition-colors <%= tab === 'reports' ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
      Báo cáo vi phạm
      <% if (pendingCount > 0) { %>
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-600">
          <%= pendingCount %>
        </span>
      <% } else { %>
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-500">
          <%= reports.length %>
        </span>
      <% } %>
    </a>
  </div>

  <%# ── Tab 1: All comments ─────────────────────────────────────────────── %>
  <% if (tab === 'comments') { %>
  <div class="p-6">
    <% if (comments.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <svg class="w-16 h-16 text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
        </svg>
        <p class="text-gray-800 font-semibold">Chưa có bình luận nào</p>
        <p class="text-sm text-gray-400 mt-1">Các bình luận trong bài học sẽ hiện ở đây.</p>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
            <th class="pb-3 pl-2 w-1/4">Người dùng</th>
            <th class="pb-3">Nội dung</th>
            <th class="pb-3 text-center w-24">Loại</th>
            <th class="pb-3 text-center w-28">Trạng thái</th>
            <th class="pb-3 text-center w-20">Thời gian</th>
            <th class="pb-3 text-center w-28">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const c of comments) { %>
          <tr class="hover:bg-gray-50/60 transition-colors" id="comment-row-<%= c.id %>">
            <%# User %>
            <td class="py-4 pl-2">
              <div class="flex items-center gap-2.5">
                <% if (c.avatar) { %>
                  <img src="<%= c.avatar %>" class="w-8 h-8 rounded-full object-cover flex-shrink-0" alt="">
                <% } else { %>
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-bold text-indigo-600"><%= c.username.charAt(0).toUpperCase() %></span>
                  </div>
                <% } %>
                <span class="font-medium text-gray-800 text-xs truncate max-w-[90px]"><%= c.username %></span>
              </div>
            </td>

            <%# Content %>
            <td class="py-4 pr-4">
              <% if (c.isReply && c.parentContent) { %>
                <p class="text-xs text-gray-400 mb-1 pl-2 border-l-2 border-gray-200 truncate max-w-xs italic">
                  ↩ <%= c.parentUsername %>: <%= c.parentContent.substring(0, 60) %><% if (c.parentContent.length > 60) { %>…<% } %>
                </p>
              <% } %>
              <% if (c.isDeleted) { %>
                <p class="text-xs text-gray-300 italic">[ Nội dung không hiển thị ]</p>
              <% } else { %>
                <p class="text-sm text-gray-700 line-clamp-2"><%= c.content %></p>
              <% } %>
            </td>

            <%# Type %>
            <td class="py-4 text-center">
              <% if (c.isReply) { %>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-blue-50 text-blue-600 text-xs font-medium">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 15-6 6m0 0-6-6m6 6V9a6 6 0 0 1 12 0v3"/></svg>
                  Trả lời
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg bg-violet-50 text-violet-600 text-xs font-medium">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8-4-4H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-3l-4 4Z"/></svg>
                  Bình luận
                </span>
              <% } %>
            </td>

            <%# Status %>
            <td class="py-4 text-center">
              <% if (c.isDeleted) { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-red-50 text-red-500 text-xs font-semibold border border-red-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Đã ẩn
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-600 text-xs font-semibold border border-emerald-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Hiển thị
                </span>
              <% } %>
            </td>

            <%# Time %>
            <td class="py-4 text-center">
              <span class="text-xs text-gray-400 whitespace-nowrap"><%= c.createdAt %></span>
            </td>

            <%# Actions %>
            <td class="py-4 text-center">
              <div class="flex items-center justify-center gap-1.5">
                <% if (!c.isDeleted) { %>
                  <button
                    onclick="commentAction('hide', '<%= c.id %>')"
                    title="Ẩn bình luận"
                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-amber-400 text-amber-500 hover:bg-amber-400 hover:text-white transition-all shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
                    </svg>
                  </button>
                <% } else { %>
                  <button
                    onclick="commentAction('restore', '<%= c.id %>')"
                    title="Khôi phục bình luận"
                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-emerald-500 text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                    </svg>
                  </button>
                <% } %>
                <button
                  onclick="confirmDeleteComment('<%= c.id %>')"
                  title="Xóa vĩnh viễn"
                  class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-red-400 text-red-400 hover:bg-red-400 hover:text-white transition-all shadow-sm">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                  </svg>
                </button>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>

  <%# ── Tab 2: Reported comments ────────────────────────────────────────── %>
  <% if (tab === 'reports') { %>
  <div class="p-6">
    <% if (reports.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <svg class="w-16 h-16 text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
        </svg>
        <p class="text-gray-800 font-semibold">Không có báo cáo nào</p>
        <p class="text-sm text-gray-400 mt-1">Chưa có bình luận nào bị báo cáo trong bài học này.</p>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="text-xs font-semibold text-gray-400 uppercase tracking-wider border-b border-gray-100">
            <th class="pb-3 pl-2 w-1/6">Người báo cáo</th>
            <th class="pb-3 w-1/4">Bình luận bị báo cáo</th>
            <th class="pb-3">Lý do</th>
            <th class="pb-3 text-center w-28">Trạng thái</th>
            <th class="pb-3 text-center w-24">Ngày báo cáo</th>
            <th class="pb-3 text-center w-36">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const r of reports) { %>
          <tr class="hover:bg-gray-50/60 transition-colors" id="report-row-<%= r.reportId %>">
            <%# Reporter %>
            <td class="py-4 pl-2">
              <div class="flex items-center gap-2">
                <% if (r.reporterAvatar) { %>
                  <img src="<%= r.reporterAvatar %>" class="w-7 h-7 rounded-full object-cover flex-shrink-0" alt="">
                <% } else { %>
                  <div class="w-7 h-7 rounded-full bg-rose-100 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-bold text-rose-500"><%= r.reporterName.charAt(0).toUpperCase() %></span>
                  </div>
                <% } %>
                <span class="text-xs font-medium text-gray-700 truncate max-w-[80px]"><%= r.reporterName %></span>
              </div>
            </td>

            <%# Comment content %>
            <td class="py-4 pr-3">
              <p class="text-xs text-gray-400 mb-0.5">tác giả: <span class="font-medium text-gray-600"><%= r.commentAuthor %></span></p>
              <% if (r.commentDeleted) { %>
                <p class="text-xs text-gray-300 italic">[ Đã bị ẩn ]</p>
              <% } else { %>
                <p class="text-sm text-gray-700 line-clamp-2"><%= r.commentContent %></p>
              <% } %>
            </td>

            <%# Reason %>
            <td class="py-4 pr-4">
              <p class="text-sm text-gray-600 line-clamp-2"><%= r.reason %></p>
            </td>

            <%# Status badge %>
            <td class="py-4 text-center">
              <% if (r.reportStatus === 'pending') { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-50 text-amber-600 text-xs font-semibold border border-amber-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>Chờ xử lý
                </span>
              <% } else if (r.reportStatus === 'accept') { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-600 text-xs font-semibold border border-emerald-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Đã chấp nhận
                </span>
              <% } else { %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-gray-100 text-gray-500 text-xs font-semibold border border-gray-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Đã từ chối
                </span>
              <% } %>
            </td>

            <%# Date %>
            <td class="py-4 text-center">
              <span class="text-xs text-gray-400 whitespace-nowrap"><%= r.reportedAt %></span>
            </td>

            <%# Actions %>
            <td class="py-4 text-center">
              <% if (r.reportStatus === 'pending') { %>
              <div class="flex flex-col items-stretch gap-1.5">
                <div class="flex items-center justify-center gap-1.5 flex-wrap">
                  <button
                    onclick="reportAction('accept', '<%= r.reportId %>')"
                    title="Ẩn bình luận"
                    class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-white border border-emerald-500 text-emerald-600 text-xs font-semibold hover:bg-emerald-500 hover:text-white transition-all shadow-sm">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4.5 12.75 6 6 9-13.5"/>
                    </svg>
                    Ẩn
                  </button>
                  <button
                    onclick="reportAction('acceptDelete', '<%= r.reportId %>')"
                    title="Xóa vĩnh viễn bình luận"
                    class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-white border border-red-400 text-red-500 text-xs font-semibold hover:bg-red-500 hover:text-white transition-all shadow-sm">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                    </svg>
                    Xóa vĩnh viễn
                  </button>
                </div>
                <button
                  onclick="reportAction('reject', '<%= r.reportId %>')"
                  title="Từ chối báo cáo"
                  class="flex items-center justify-center gap-1 px-2.5 py-1.5 rounded-lg bg-white border border-gray-300 text-gray-500 text-xs font-semibold hover:bg-gray-100 transition-all shadow-sm w-full">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/>
                  </svg>
                  Từ chối
                </button>
              </div>
              <% } else { %>
                <span class="text-xs text-gray-300 italic">Đã xử lý</span>
              <% } %>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>
</div>

<%# ── Confirm delete modal ────────────────────────────────────────────────── %>
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-base font-bold text-gray-800">Xóa vĩnh viễn bình luận</h3>
        <p class="text-xs text-gray-500 mt-0.5">Hành động này không thể hoàn tác.</p>
      </div>
    </div>
    <p class="text-sm text-gray-600 mb-6">Bình luận và toàn bộ phản hồi liên quan sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
    <div class="flex gap-3 justify-end">
      <button onclick="closeDeleteModal()"
              class="px-4 py-2 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
        Hủy
      </button>
      <button id="confirmDeleteBtn"
              class="px-4 py-2 rounded-xl bg-red-500 text-white text-sm font-bold hover:bg-red-600 transition-colors shadow-md shadow-red-100">
        Xóa vĩnh viễn
      </button>
    </div>
  </div>
</div>

<%# ── Toast notification ──────────────────────────────────────────────────── %>
<div id="toast"
     class="fixed bottom-6 right-6 z-50 hidden items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white transition-all">
</div>

<script>
  let pendingDeleteId = null;

  async function commentAction(action, commentId) {
    const urlMap = {
      hide:    `/admin/lesson/comment/${commentId}/hide`,
      restore: `/admin/lesson/comment/${commentId}/restore`,
    };
    try {
      const res = await axios.post(urlMap[action]);
      if (res.data.ok) {
        showToast(action === 'hide' ? 'Đã ẩn bình luận' : 'Đã khôi phục bình luận',
                  action === 'hide' ? 'warn' : 'success');
        setTimeout(() => location.reload(), 800);
      }
    } catch {
      showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
    }
  }

  function confirmDeleteComment(commentId) {
    pendingDeleteId = commentId;
    document.getElementById('deleteModal').classList.remove('hidden');
    document.getElementById('deleteModal').classList.add('flex');
  }

  function closeDeleteModal() {
    pendingDeleteId = null;
    document.getElementById('deleteModal').classList.add('hidden');
    document.getElementById('deleteModal').classList.remove('flex');
  }

  document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    try {
      const res = await axios.post(`/admin/lesson/comment/${pendingDeleteId}/delete`);
      if (res.data.ok) {
        closeDeleteModal();
        showToast('Đã xóa bình luận vĩnh viễn', 'error');
        setTimeout(() => location.reload(), 800);
      }
    } catch {
      showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
    }
  });

  async function reportAction(action, reportId) {
    if (action === 'acceptDelete' && !confirm('Xóa vĩnh viễn bình luận này? Không thể hoàn tác.')) return;
    const urlMap = {
      accept: `/admin/lesson/report/${reportId}/accept`,
      acceptDelete: `/admin/lesson/report/${reportId}/accept-delete`,
      reject: `/admin/lesson/report/${reportId}/reject`,
    };
    try {
      const res = await axios.post(urlMap[action]);
      if (res.data.ok) {
        const msg =
          action === 'accept' ? 'Đã ẩn bình luận' :
          action === 'acceptDelete' ? 'Đã xóa bình luận vĩnh viễn' :
          'Đã từ chối báo cáo';
        showToast(msg, action === 'reject' ? 'warn' : 'success');
        setTimeout(() => location.reload(), 800);
      }
    } catch {
      showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
    }
  }

  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    const colors = {
      success: 'bg-emerald-500',
      warn:    'bg-amber-500',
      error:   'bg-red-500',
    };
    const icons = {
      success: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m4.5 12.75 6 6 9-13.5"/></svg>',
      warn:    '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>',
      error:   '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/></svg>',
    };
    toast.className = `fixed bottom-6 right-6 z-50 flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white transition-all ${colors[type]}`;
    toast.innerHTML = icons[type] + message;
    toast.classList.remove('hidden');
    setTimeout(() => { toast.classList.add('hidden'); }, 3000);
  }

  document.getElementById('deleteModal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
  });
</script>
