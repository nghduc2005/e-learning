<p class="text-sm text-gray-500 -mt-4 mb-4">Theo dõi hiệu suất và tương tác của người dùng trên nền tảng.</p>
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800 tracking-tight">Thống kê tương tác</h2>
    <div class="bg-white p-1 rounded-xl shadow-sm border border-gray-100 flex items-center space-x-1">
        <a href="?period=all" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all <%= period === 'all' ? 'bg-indigo-50 text-indigo-700 shadow-sm' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50' %>">Tất cả thời gian</a>
        <a href="?period=month" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all <%= period === 'month' ? 'bg-indigo-50 text-indigo-700 shadow-sm' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50' %>">Tháng này</a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8 font-sans">
    
    <!-- Card 1: Khóa học đăng ký nhiều nhất -->
    <div class="bg-gradient-to-br from-indigo-500 to-purple-600 rounded-3xl p-1 shadow-lg shadow-indigo-200 hover:-translate-y-1 transition-all duration-300">
        <div class="bg-white/10 backdrop-blur-sm rounded-[22px] h-full p-6 flex flex-col justify-between border border-white/20">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-white/20 rounded-2xl">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                    <span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full">Top Đăng ký</span>
                </div>
                <h3 class="text-white text-2xl font-black mb-1"><%= stats.mostRegisteredCourse.students.toLocaleString() %></h3>
                <p class="text-indigo-100 text-sm font-medium">Học viên tham gia</p>
            </div>
            
            <div class="mt-6 flex items-center bg-white/10 p-3 rounded-2xl border border-white/10">
                <img src="<%= stats.mostRegisteredCourse.image %>" class="w-12 h-12 rounded-xl object-cover shadow-sm" alt="Course Image">
                <div class="ml-3">
                    <p class="text-white text-sm font-bold line-clamp-2 leading-tight"><%= stats.mostRegisteredCourse.name %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2: Khóa học đánh giá cao nhất -->
    <div class="bg-gradient-to-br from-emerald-400 to-teal-500 rounded-3xl p-1 shadow-lg shadow-emerald-200 hover:-translate-y-1 transition-all duration-300">
        <div class="bg-white/10 backdrop-blur-sm rounded-[22px] h-full p-6 flex flex-col justify-between border border-white/20">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-white/20 rounded-2xl">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                    </div>
                    <span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full">Top Đánh giá</span>
                </div>
                <div class="flex items-baseline space-x-2 mb-1">
                    <h3 class="text-white text-2xl font-black"><%= stats.topRatedCourse.rating %></h3>
                    <span class="text-emerald-100 text-sm font-medium">/ 5.0</span>
                </div>
                <p class="text-emerald-100 text-sm font-medium"><%= stats.topRatedCourse.reviews.toLocaleString() %> lượt đánh giá</p>
            </div>
            
            <div class="mt-6 flex items-center bg-white/10 p-3 rounded-2xl border border-white/10">
                <img src="<%= stats.topRatedCourse.image %>" class="w-12 h-12 rounded-xl object-cover shadow-sm" alt="Course Image">
                <div class="ml-3">
                    <p class="text-white text-sm font-bold line-clamp-2 leading-tight"><%= stats.topRatedCourse.name %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3: Tương tác cao nhất (Bình luận) -->
    <div class="bg-gradient-to-br from-rose-400 to-orange-500 rounded-3xl p-1 shadow-lg shadow-rose-200 hover:-translate-y-1 transition-all duration-300 md:col-span-2 xl:col-span-1">
        <div class="bg-white/10 backdrop-blur-sm rounded-[22px] h-full p-6 flex flex-col justify-between border border-white/20">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-white/20 rounded-2xl">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
                    </div>
                    <span class="px-3 py-1 bg-white/20 text-white text-xs font-bold rounded-full">Top Tương tác</span>
                </div>
                <h3 class="text-white text-2xl font-black mb-1"><%= stats.topCommented.comments.toLocaleString() %></h3>
                <p class="text-rose-100 text-sm font-medium">Bình luận & thảo luận</p>
            </div>
            
            <div class="mt-6 bg-white/10 p-4 rounded-2xl border border-white/10">
                <div class="flex items-center mb-1">
                    <span class="bg-white/20 text-white text-[10px] uppercase font-bold px-2 py-0.5 rounded mr-2"><%= stats.topCommented.type %></span>
                </div>
                <p class="text-white text-sm font-bold line-clamp-2 leading-tight"><%= stats.topCommented.name %></p>
            </div>
        </div>
    </div>
</div>

<!-- 5 Cập nhật mới nhất -->
<div class="bg-white rounded-[2rem] shadow-sm border border-gray-100 overflow-hidden font-sans">
    <div class="px-8 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
        <div>
            <h3 class="text-lg font-bold text-gray-800">Hoạt động gần đây</h3>
            <p class="text-sm text-gray-500 font-medium mt-1">5 nội dung được cập nhật mới nhất trong hệ thống</p>
        </div>
        <div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
    </div>
    <div class="p-6">
        <div class="relative">
            <!-- Timeline line -->
            <div class="absolute top-4 bottom-4 left-5 w-px bg-gray-200"></div>
            
            <ul class="space-y-6">
                <% stats.newestUpdates.forEach((update, index) => { 
                    // Dynamic color based on type
                    let dotColor = "bg-indigo-500 ring-indigo-100";
                    let badgeColor = "bg-indigo-50 text-indigo-700 border-indigo-100";
                    
                    if(update.type === 'Khóa học') {
                        dotColor = "bg-emerald-500 ring-emerald-100";
                        badgeColor = "bg-emerald-50 text-emerald-700 border-emerald-100";
                    } else if(update.type === 'Bài học') {
                        dotColor = "bg-rose-500 ring-rose-100";
                        badgeColor = "bg-rose-50 text-rose-700 border-rose-100";
                    } else if(update.type === 'Chương') {
                        dotColor = "bg-amber-500 ring-amber-100";
                        badgeColor = "bg-amber-50 text-amber-700 border-amber-100";
                    }
                %>
                <li class="relative pl-12 group">
                    <div class="absolute left-0 top-1 w-10 h-10 flex items-center justify-center">
                        <div class="w-3 h-3 rounded-full <%= dotColor %> ring-4 shadow-sm z-10 transition-transform group-hover:scale-125 duration-300"></div>
                    </div>
                    <div class="bg-white border border-gray-100 p-4 rounded-2xl hover:shadow-md hover:border-gray-200 transition-all duration-200">
                        <div class="flex justify-between items-start mb-1">
                            <h4 class="font-bold text-gray-800 text-base"><%= update.name %></h4>
                            <span class="text-xs font-semibold text-gray-400 bg-gray-50 px-2 py-1 rounded-lg"><%= update.time %></span>
                        </div>
                        <div class="flex items-center mt-2 space-x-3">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold border <%= badgeColor %>">
                                <%= update.type %>
                            </span>
                            
                            <% if(update.status === 'active') { %>
                                <span class="text-xs font-semibold text-emerald-600 flex items-center">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span> Hoạt động
                                </span>
                            <% } else if(update.status === 'hidden') { %>
                                <span class="text-xs font-semibold text-gray-500 flex items-center">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400 mr-1.5"></span> Đã ẩn
                                </span>
                            <% } else if(update.status === 'deleted') { %>
                                <span class="text-xs font-semibold text-red-600 flex items-center">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 mr-1.5"></span> Đã chuyển vào Thùng rác
                                </span>
                            <% } else { %>
                                <span class="text-xs font-semibold text-amber-600 flex items-center">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-1.5"></span> Đã khóa
                                </span>
                            <% } %>
                        </div>
                    </div>
                </li>
                <% }) %>
            </ul>
        </div>
    </div>
</div>
