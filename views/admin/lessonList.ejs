<div class="flex w-full justify-between items-center mb-6"> 
  <div class="flex-1 max-w-2xl flex gap-2">
    <%- include("../layouts/components/search.ejs")%>
    <button type="button" id="dropdownBgHoverButton" data-dropdown-toggle="dropdownBgHover"
            class="h-[42px] inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:text-indigo-600 hover:border-indigo-200 focus:ring-4 focus:outline-none focus:ring-indigo-50 shadow-sm transition-all duration-200">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
      </svg>
      Bộ lọc
    </button>
    <div id="dropdownBgHover" class="absolute left-0 md:left-auto md:right-0 mt-2 z-20 hidden w-[450px] bg-white rounded-2xl shadow-2xl border border-gray-100 p-4">
        <div class="grid grid-cols-2 gap-6">
            
            <div>
                <span class="block mb-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Trạng thái</span>
                <div class="space-y-1">
                    <label class="flex items-center p-2 rounded-xl hover:bg-indigo-50 group cursor-pointer transition-colors">
                        <input type="checkbox" name="status" value="active" class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                        <span class="ms-3 text-sm font-medium text-gray-700 group-hover:text-indigo-700">Đang hoạt động</span>
                    </label>
                    <label class="flex items-center p-2 rounded-xl hover:bg-indigo-50 group cursor-pointer transition-colors">
                        <input type="checkbox" name="status" value="hidden" class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                        <span class="ms-3 text-sm font-medium text-gray-700 group-hover:text-indigo-700">Ẩn</span>
                    </label>
                    <label class="flex items-center p-2 rounded-xl hover:bg-indigo-50 group cursor-pointer transition-colors">
                        <input type="checkbox" name="status" value="locked" class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                        <span class="ms-3 text-sm font-medium text-gray-700 group-hover:text-indigo-700">Khóa</span>
                    </label>
                </div>
            </div>
    
            <div>
                <span class="block mb-2 text-xs font-bold text-gray-400 uppercase tracking-wider">Thời gian</span>
                <div class="space-y-2">
                    <select name="time" class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 p-2">
                        <option value="all" selected>Tất cả thời gian</option>
                        <option value="this_month">Tháng này</option>
                        <option value="3_months">3 tháng qua</option>
                        <option value="this_year">Năm nay</option>
                    </select>
                </div>
            </div>
        </div>
    
        <div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center">
            <button id="btnClearFilter" class="text-sm text-gray-500 hover:text-red-500 font-medium transition-colors">Xóa tất cả</button>
            <button id="btnApplyFilter" class="px-4 py-2 bg-indigo-600 text-white text-sm font-bold rounded-lg hover:bg-indigo-700 shadow-md transition-all">
                Áp dụng
            </button>
        </div>
    </div>
  </div>
  
  <%- include("../layouts/components/createButton.ejs", {
    type: "lesson"
  })%>
</div>

<script>
  document.getElementById('btnApplyFilter')?.addEventListener('click', () => {
    const url = new URL(window.location.href);
    
    const checkedStatuses = Array.from(document.querySelectorAll('input[name="status"]:checked')).map(cb => cb.value);
    if (checkedStatuses.length > 0) {
      url.searchParams.set('status', checkedStatuses.join(','));
    } else {
      url.searchParams.delete('status');
    }

    const time = document.querySelector('select[name="time"]')?.value;
    if (time && time !== 'all') url.searchParams.set('time', time);
    else url.searchParams.delete('time');

    url.searchParams.delete('page');
    window.location.href = url.toString();
  });

  document.getElementById('btnClearFilter')?.addEventListener('click', () => {
    const url = new URL(window.location.href);
    url.searchParams.delete('status');
    url.searchParams.delete('time');
    window.location.href = url.toString();
  });

  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    let activeFiltersCount = 0;
    
    const statusParam = params.get('status');
    if (statusParam) {
      const statuses = statusParam.split(',');
      activeFiltersCount += statuses.length;
      statuses.forEach(st => {
        const checkbox = document.querySelector(`input[name="status"][value="${st}"]`);
        if (checkbox) checkbox.checked = true;
      });
    }

    const timeParam = params.get('time');
    if (timeParam && timeParam !== 'all') {
        activeFiltersCount++;
        const el = document.querySelector('select[name="time"]');
        if (el) el.value = timeParam;
    }

    if (activeFiltersCount > 0) {
        const filterBtn = document.getElementById('dropdownBgHoverButton');
        if (filterBtn) {
          filterBtn.classList.remove('text-gray-600', 'border-gray-200');
          filterBtn.classList.add('text-indigo-700', 'border-indigo-600', 'bg-indigo-50');
          filterBtn.innerHTML += `<span class="inline-flex items-center justify-center w-5 h-5 ms-2 text-xs font-bold text-white bg-indigo-600 rounded-full shadow-sm">${activeFiltersCount}</span>`;
        }
    }
  });
</script>

<%- include("../layouts/components/tableLesson.ejs", {
  lessonList: typeof lessonList !== 'undefined' ? lessonList : [],
  pagination: typeof pagination !== 'undefined' ? pagination : null,
  query: typeof query !== 'undefined' ? query : {}
})%>
