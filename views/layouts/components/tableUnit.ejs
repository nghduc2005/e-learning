<div class="relative rounded-2xl overflow-x-auto p-6 bg-gray-50 font-sans">
  <% if (typeof unitList !== 'undefined' && unitList.length > 0) { %>
  <table class="w-full rounded-2xl text-sm text-left text-gray-700 border-separate" style="border-spacing: 0 12px;">
      
      <thead class="text-xs text-gray-400 rounded-2xl uppercase tracking-widest font-semibold bg-white shadow-sm">
        <tr>
            <th scope="col" class="px-6 py-4 rounded-l-2xl border-y border-l border-gray-100 text-left">
              TÊN CHƯƠNG
          </th>
          <th scope="col" class="px-6 py-4 border-y border-gray-100 text-center">
              TRẠNG THÁI
          </th>
          <th scope="col" class="px-6 py-4 border-y border-gray-100 text-center">
              <% if (typeof isTrash !== 'undefined' && isTrash) { %>
                NGÀY XÓA
              <% } else { %>
                NGÀY TẠO
              <% } %>
          </th>
          <th scope="col" class="px-6 py-4 border-y border-r border-gray-100 text-center rounded-r-2xl">
              THAO TÁC
          </th>
        </tr>
    </thead>
      
      <tbody>
          <% for(let i = 0; i < unitList.length; i++) {%> 
          <tr class="bg-white rounded-2xl hover:shadow-lg transition-all duration-300 group">

              <td class="px-6 py-5 rounded-s-2xl border-y border-s border-gray-100">
                  <p class="font-semibold text-gray-900 text-base group-hover:text-indigo-600 transition-colors">
                      <%=unitList[i].name%>
                  </p>
              </td>
              
              <td class="px-6 py-5 border-y border-gray-100 text-center">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold border <%=unitList[i].status.bgClass%>">
                      <span class="w-2 h-2 mr-2 rounded-full <%=unitList[i].status.dotClass%>"></span>
                      <%=unitList[i].status.text%>
                  </span>
              </td>
              
              <td class="px-6 py-5 border-y border-gray-100 text-center font-medium text-gray-500">
                  <% if (typeof isTrash !== 'undefined' && isTrash) { %>
                    <%=unitList[i].deletedAt%>
                  <% } else { %>
                    <%=unitList[i].createdAt%>
                  <% } %>
              </td>

              <td class="px-8 py-5 rounded-e-2xl border-y border-e border-gray-100">
                <div class="flex justify-center items-center space-x-3">
                  <% if (typeof isTrash !== 'undefined' && isTrash) { %>
                    <form method="POST" action="/admin/unit/restore/<%=unitList[i].id%>" onsubmit="return confirm('Bạn có chắc chắn muốn khôi phục chương này?');">
                        <button type="submit" title="Khôi phục" 
                                class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-emerald-500 text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all duration-200 shadow-sm">
                            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
                        </button>
                    </form>
                  <% } else { %>
                  <a href="/admin/unit/edit/<%=unitList[i].id%>">
                  <button title="Chỉnh sửa" 
                          class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all duration-200 shadow-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>                          
                  </button>
                  </a>
                  <form method="POST" action="/admin/unit/delete/<%=unitList[i].id%>" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chương này vào Thùng rác?');">
                      <button type="submit" title="Xóa" 
                              class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all duration-200 shadow-sm">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                          </svg>                          
                      </button>
                  </form>
                  <% } %>
                </div>
            </td>
          </tr>
          <%}%>
      </tbody>
  </table>
  <nav aria-label="Page navigation example" class="mt-8 w-full flex flex-col items-center justify-center space-y-4">
      <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
      <% 
        function getPageUrl(p) {
           const urlParams = new URLSearchParams(query);
           urlParams.set('page', p);
           return '?' + urlParams.toString();
        }
      %>
      <ul class="flex items-center space-x-2 text-sm">
          <li>
              <% if (pagination.page > 1) { %>
              <a href="<%= getPageUrl(pagination.page - 1) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all duration-200 shadow-sm">
                  <span class="sr-only">Previous</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
              </a>
              <% } else { %>
              <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 text-gray-300 shadow-sm cursor-not-allowed">
                  <span class="sr-only">Previous</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
              </div>
              <% } %>
          </li>

          <% for (let p = 1; p <= pagination.totalPages; p++) { %>
            <li>
                <% if (p === pagination.page) { %>
                <a href="javascript:void(0)" aria-current="page" class="flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-600 text-white font-bold shadow-lg shadow-indigo-100 transition-all duration-200"><%= p %></a>
                <% } else { %>
                <a href="<%= getPageUrl(p) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-600 font-semibold hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all duration-200 shadow-sm"><%= p %></a>
                <% } %>
            </li>
          <% } %>

          <li>
              <% if (pagination.page < pagination.totalPages) { %>
              <a href="<%= getPageUrl(pagination.page + 1) %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all duration-200 shadow-sm">
                  <span class="sr-only">Next</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
              </a>
              <% } else { %>
              <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 text-gray-300 shadow-sm cursor-not-allowed">
                  <span class="sr-only">Next</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
              </div>
              <% } %>
          </li>
      </ul>
      <span class="text-xs font-semibold text-gray-400">Hiển thị trang <%= pagination.page %> / <%= pagination.totalPages %> (<%= pagination.totalItems %> chương)</span>
      <% } %>
  </nav>
  
  <% } else { %>
    <div class="flex flex-col items-center justify-center py-16 bg-white rounded-2xl border border-gray-100 shadow-sm mt-4">
        <svg class="w-20 h-20 text-gray-200 mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.143 17.082a24.248 24.248 0 003.844.148m-3.844-.148a23.856 23.856 0 01-5.456-1.04 2.39 2.39 0 01-1.418-1.419A23.846 23.846 0 011.125 9.12a23.846 23.846 0 011.141-5.455 2.389 2.389 0 011.418-1.418 23.858 23.858 0 015.456-1.04m0 15.836a23.659 23.659 0 005.456-1.04 2.389 2.389 0 001.418-1.419c.36-1.833.553-3.746.553-5.714 0-1.968-.193-3.881-.553-5.714a2.389 2.389 0 00-1.418-1.418 23.858 23.858 0 00-5.456-1.04m0 15.836h.008v.008h-.008v-.008zM9.143 8.127h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>
        </svg>
        <h3 class="text-lg font-bold text-gray-800 mb-1">Không tìm thấy dữ liệu</h3>
        <p class="text-gray-500 font-medium text-sm">Chưa có chương nào hoặc không tìm thấy kết quả phù hợp với bộ lọc của bạn.</p>
    </div>
  <% } %>
</div>