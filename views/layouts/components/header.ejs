<header class="flex items-center justify-between h-16 px-6 bg-white border-b border-gray-200 shadow-sm sticky top-0 z-40">
  <div class="flex items-center flex-1">
  </div>

  <div class="flex items-center space-x-4">
    
    <button class="relative p-2 text-gray-500 hover:bg-gray-100 rounded-full transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
      <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 border-2 border-white rounded-full"></span>
    </button>

    <div class="h-8 border-l border-gray-200"></div>

    <div class="relative group inline-block">
    
      <div class="flex items-center space-x-3 p-1 pr-3 rounded-lg bg-white border border-gray-100 shadow-sm transition-all duration-200 cursor-pointer group-hover:shadow-md group-hover:border-indigo-100">
          <div class="w-9 h-9 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold shadow-sm text-sm">
              <%= typeof currentAdmin !== 'undefined' && currentAdmin ? currentAdmin.username.substring(0,2).toUpperCase() : 'AD' %>
          </div>
          <div class="text-left hidden md:block">
              <p class="text-xs font-bold text-gray-800 leading-none font-sans"><%= typeof currentAdmin !== 'undefined' && currentAdmin ? currentAdmin.username : 'Admin' %></p>
              <p class="text-[10px] text-gray-500 mt-1 uppercase tracking-tighter">Quản trị viên</p>
          </div>
          <svg class="w-4 h-4 text-gray-400 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
      </div>
  
      <div class="absolute right-0 w-56 pt-2 hidden group-hover:block z-[100] animate-in fade-in zoom-in duration-200">
          <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 overflow-hidden">
              
              <div class="px-4 py-3 border-b border-gray-50 bg-gray-50/50">
                  <p class="text-xs text-gray-400 uppercase font-bold tracking-wider">Tài khoản</p>
                  <p class="text-sm font-semibold text-gray-900 mt-1 truncate"><%= typeof currentAdmin !== 'undefined' && currentAdmin ? currentAdmin.email : '' %></p>
              </div>
  
              <div class="p-2 space-y-1">
                  <a href="/admin/profile" class="flex items-center space-x-3 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors group/item">
                      <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center group-hover/item:bg-indigo-100 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>                        
                      </div>
                      <span class="font-medium">Thông tin cá nhân</span>
                  </a>
  
                  <a href="/admin/settings" class="flex items-center space-x-3 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors group/item">
                      <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center group-hover/item:bg-indigo-100 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>                        
                      </div>
                      <span class="font-medium">Cài đặt hệ thống</span>
                  </a>
              </div>
  
              <div class="p-2 mt-1 border-t border-gray-50">
                  <form action="/admin/auth/logout" method="POST">
                    <button type="submit" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-xl text-sm text-red-600 hover:bg-red-50 transition-colors group/logout cursor-pointer">
                        <div class="w-8 h-8 rounded-lg bg-red-100/50 flex items-center justify-center group-hover/logout:bg-red-100 transition-colors">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                          </svg>
                        </div>
                        <span class="font-bold">Đăng xuất tài khoản</span>
                    </button>
                  </form>
              </div>
          </div>
      </div>
  </div>
    
  </div>
</header>