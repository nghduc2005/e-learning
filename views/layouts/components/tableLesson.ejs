<% const isTrashView = typeof isTrash !== 'undefined' && isTrash; %>
<div class="relative rounded-2xl overflow-x-auto p-6 bg-gray-50 font-sans">
  <table class="w-full rounded-2xl text-sm text-left text-gray-700 border-separate" style="border-spacing: 0 12px;">
      
      <thead class="text-xs text-gray-400 rounded-2xl uppercase tracking-widest font-semibold bg-white shadow-sm">
        <tr>
            <th scope="col" class="px-6 py-4 rounded-l-2xl border-y border-l border-gray-100 text-left">
              TÊN BÀI HỌC
          </th>
          <th scope="col" class="px-6 py-4 border-y border-gray-100 text-center">
              TRẠNG THÁI
          </th>
          <th scope="col" class="px-6 py-4 border-y border-gray-100 text-center">
              <%= isTrashView ? 'NGÀY XÓA' : 'NGÀY TẠO' %>
          </th>
          <th scope="col" class="px-6 py-4 border-y border-r border-gray-100 text-center rounded-r-2xl">
              THAO TÁC
          </th>
        </tr>
    </thead>
      
      <tbody>
        <% if (lessonList && lessonList.length > 0) { %>
            <% lessonList.forEach(lesson => { %>
                <tr class="bg-white hover:shadow-lg transition-all duration-300 group">
                    <td class="px-6 py-5 rounded-s-2xl border-y border-s border-gray-100 font-semibold text-gray-900 text-base group-hover:text-indigo-600 transition-colors">
                        <a href="/admin/lesson/detail/<%= lesson.id %>">
                            <%= lesson.name %>
                        </a>
                    </td>
                    <td class="px-6 py-5 border-y border-gray-100 text-center">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold <%= lesson.statusDisplay.bgClass %>">
                            <span class="w-2 h-2 mr-2 rounded-full <%= lesson.statusDisplay.dotClass %>"></span>
                            <%= lesson.statusDisplay.text %>
                        </span>
                    </td>
                    <td class="px-6 py-5 border-y border-gray-100 text-center font-medium text-gray-500">
                        <% if (isTrashView) { %>
                          <%= lesson.deletedAt %>
                        <% } else { %>
                          <%= lesson.createdAt %>
                        <% } %>
                    </td>
                    <td class="px-8 py-5 rounded-e-2xl border-y border-e border-gray-100">
                        <div class="flex justify-center items-center space-x-3">
                            <% if (isTrashView) { %>
                                <form action="/admin/lesson/restore/<%= lesson.id %>" method="POST" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn khôi phục bài học này?');">
                                    <button type="submit" title="Khôi phục" 
                                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-emerald-600 text-emerald-600 hover:bg-emerald-600 hover:text-white transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                                        </svg>
                                    </button>
                                </form>
                            <% } else { %>
                                <a href="/admin/lesson/<%= lesson.id %>/comments">
                                    <button title="Quản lý bình luận"
                                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-violet-500 text-violet-500 hover:bg-violet-500 hover:text-white transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
                                        </svg>
                                    </button>
                                </a>
                                <a href="/admin/lesson/edit/<%= lesson.id %>">
                                    <button title="Chỉnh sửa"
                                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                        </svg>
                                    </button>
                                </a>
                                <form action="/admin/lesson/delete/<%= lesson.id %>" method="POST" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài học này vào Thùng rác?');">
                                    <button type="submit" title="Xóa" 
                                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-white border border-red-600 text-red-600 hover:bg-red-600 hover:text-white transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                        </svg>                          
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-500 bg-white rounded-2xl border border-gray-100">
                    Không có dữ liệu bài học.
                </td>
            </tr>
        <% } %>
      </tbody>
  </table>

  <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-8 w-full flex justify-center">
        <ul class="flex items-center space-x-2 text-sm">
            <% if (pagination.currentPage > 1) { %>
            <li>
                <a href="?<%= new URLSearchParams({...query, page: pagination.currentPage - 1}).toString() %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all duration-200 shadow-sm">
                    <span class="sr-only">Previous</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
                </a>
            </li>
            <% } %>
  
            <% for(let i = 1; i <= pagination.totalPages; i++) { %>
            <li>
                <a href="?<%= new URLSearchParams({...query, page: i}).toString() %>" class="flex items-center justify-center w-10 h-10 rounded-xl <%= pagination.currentPage === i ? 'bg-indigo-600 text-white font-bold shadow-lg shadow-indigo-100' : 'bg-white border border-gray-200 text-gray-600 font-semibold hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 shadow-sm' %> transition-all duration-200"><%= i %></a>
            </li>
            <% } %>
  
            <% if (pagination.currentPage < pagination.totalPages) { %>
            <li>
                <a href="?<%= new URLSearchParams({...query, page: pagination.currentPage + 1}).toString() %>" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-gray-500 hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200 transition-all duration-200 shadow-sm">
                    <span class="sr-only">Next</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
                </a>
            </li>
            <% } %>
        </ul>
    </nav>
  <% } %>
</div>