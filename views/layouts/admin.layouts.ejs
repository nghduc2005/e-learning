<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/admin/assets/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
  <title><%= title%></title>
</head>
<body>
  <div class="flex items-start min-h-screen">
    <%- include('./components/sidebar.ejs')%>
    <main class="flex-1 min-w-0 flex flex-col">
        <%- include('./components/header.ejs') %>
        <div class="flex-1 p-6 lg:px-10">
          <div class="container mx-auto">
            <div class="mb-8 flex items-center justify-between">
                  <div>
                      <h2 class="text-4xl font-bold text-gray-800 tracking-tight">
                          <%= typeof title !== 'undefined' ? title : 'Tổng quan' %>
                      </h2>
                  </div>
              </div>
            <%- body %>
          </div>
        </div>
    </main>
  </div>
  <%# script tổng cho toàn bộ các file dùng layout%>
  <%# script riêng cho từng file%>
  <%- script %>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script src="/admin/assets/js/script.js"></script>
</body>
</html>